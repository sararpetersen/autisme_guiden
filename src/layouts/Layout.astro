---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import AccessibilityToolbar from "../components/AccessibilityToolbar.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogtitle?: string;
  ogdescription?: string;
}

const {
  title,
  description = "AutismeGuiden – Din digitale guide til autisme og neurodivergens. Information, ressourcer og støtte til neurodivergente, pårørende, lærere og fagfolk.",
  image = "/images/og-image.png",
  ogtitle,
  ogdescription,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://autismeguiden.dk");
---

<!doctype html>
<html lang="da" data-theme="light" data-font-size="normal" data-reduced-motion="false" data-colors="normal">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogtitle ?? title} />
    <meta property="og:description" content={ogdescription ?? description} />
    <meta property="og:image" content={new URL(image, canonicalURL).href} />
    <meta property="og:locale" content="da_DK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogtitle ?? title} />
    <meta name="twitter:description" content={ogdescription ?? description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL).href} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/autismeguiden_logo_1-2.png" />
    <link rel="apple-touch-icon" href="/autismeguiden_logo_1-2.png" />

    <title>{title}</title>

    <!-- Prevent FOUC and animation flicker: restore user preferences and hide
         animatable elements before first paint. is:inline keeps these synchronous. -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("ag-theme") ?? "light";
        var fontSize = localStorage.getItem("ag-font-size") ?? "normal";
        var reducedMotion = localStorage.getItem("ag-reduced-motion") ?? "false";
        var fadedColors = localStorage.getItem("ag-faded-colors") === "true" ? "faded" : "normal";
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-font-size", fontSize);
        document.documentElement.setAttribute("data-reduced-motion", reducedMotion);
        document.documentElement.setAttribute("data-colors", fadedColors);
        document.documentElement.classList.add("js-anim");
      })();
    </script>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- Skip to content -->
    <a href="#main-content" class="skip-link"> Gå til indhold </a>

    <Navbar />
    <AccessibilityToolbar />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />

    <script>
      (function () {
        const supportsObserver = typeof window !== "undefined" && "IntersectionObserver" in window;
        const prefersReducedMotion = document.documentElement.getAttribute("data-reduced-motion") === "true";
        const elements = Array.from(document.querySelectorAll<HTMLElement>("[data-animate], .section, .card")).filter(
          (el) => getComputedStyle(el).position !== "fixed" && !el.closest("#accessibility-toolbar") && !el.closest("nav") && !el.closest("header"),
        );

        function initAnimation(el: HTMLElement) {
          if (!el.dataset.animate) {
            if (el.classList.contains("card")) {
              el.dataset.animate = "animate__zoomIn";
              el.dataset.delay = el.dataset.delay || "200";
            } else {
              el.dataset.animate = "animate__fadeInUp";
              el.dataset.delay = el.dataset.delay || "150";
            }
          }
          el.classList.add("animate__animated");
          const animation = el.dataset.animate;
          if (animation) el.classList.add(animation);
          const delay = el.dataset.delay;
          if (delay) el.classList.add(`animate__delay-${delay}`);
        }

        if (!supportsObserver || prefersReducedMotion) {
          elements.forEach(initAnimation);
          return;
        }

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const target = entry.target as HTMLElement;
              initAnimation(target);
              obs.unobserve(entry.target);
            });
          },
          { threshold: 0.15 },
        );

        elements.forEach((el) => observer.observe(el));
      })();
    </script>
  </body>
</html>
