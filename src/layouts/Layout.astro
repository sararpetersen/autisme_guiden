---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import AccessibilityToolbar from "../components/AccessibilityToolbar.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "AutismeGuiden – Din digitale guide til autisme. Information, ressourcer og støtte til autistiske personer, pårørende, lærere og fagfolk.",
  image = "/images/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://autismeguiden.dk");
---

<!doctype html>
<html lang="da" data-theme="light" data-font-size="normal" data-reduced-motion="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="da_DK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- Skip to content -->
    <a href="#main-content" class="skip-link"> Gå til indhold </a>

    <Navbar />
    <AccessibilityToolbar />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />

    <script>
      // Restore user preferences from localStorage
      (function () {
        const theme = localStorage.getItem("ag-theme") ?? "light";
        const fontSize = localStorage.getItem("ag-font-size") ?? "normal";
        const reducedMotion = localStorage.getItem("ag-reduced-motion") ?? "false";

        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-font-size", fontSize);
        document.documentElement.setAttribute("data-reduced-motion", reducedMotion);
      })();
    </script>
  </body>
</html>
