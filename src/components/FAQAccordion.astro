---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  id?: string;
}

const { items, id = "faq" } = Astro.props;
---

<ul class="space-y-2" role="list" aria-label="Ofte stillede spørgsmål" id={id}>
  {
    items.map((item, i) => (
      <li class="card overflow-hidden">
        <button
          class="w-full flex items-center justify-between gap-4 px-5 py-4 text-left transition-all hover:opacity-80 focus-visible:ring-inset"
          style="color: var(--color-text);"
          aria-expanded="false"
          aria-controls={`faq-answer-${id}-${i}`}
          id={`faq-btn-${id}-${i}`}
        >
          <span
            class="font-bold text-sm sm:text-base pr-2"
            set:html={item.question}
            style="font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.03em;"
          />
          <span
            class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-all duration-200"
            style="background: var(--color-primary-100);"
            aria-hidden="true"
          >
            <svg
              class="w-3.5 h-3.5 transition-transform duration-200 faq-chevron"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              style="color: var(--color-primary);"
            >
              <path d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </button>

        <div id={`faq-answer-${id}-${i}`} class="accordion-content" role="region" aria-labelledby={`faq-btn-${id}-${i}`}>
          <div class="px-5 pb-5">
            <div class="pt-1 border-t" style="border-color: var(--color-border);">
              <p class="text-sm leading-relaxed pt-4 font-reading" set:html={item.answer} style="color: var(--color-text-muted);" />
            </div>
          </div>
        </div>
      </li>
    ))
  }
</ul>

<script>
  document.querySelectorAll('[aria-controls^="faq-answer"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      const controlsId = btn.getAttribute("aria-controls");
      if (!controlsId) return;
      const content = document.getElementById(controlsId);
      const chevron = btn.querySelector(".faq-chevron") as HTMLElement | null;
      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!isExpanded));
      content?.classList.toggle("open", !isExpanded);
      if (chevron) chevron.style.transform = isExpanded ? "rotate(0deg)" : "rotate(180deg)";
    });
  });
</script>
