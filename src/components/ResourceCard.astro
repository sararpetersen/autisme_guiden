---
interface Props {
  title: string;
  description: string;
  category: string;
  categoryColor?: string;
  href?: string;
  icon?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, category, categoryColor = "var(--color-primary)", href, icon = "📄", tags = [], featured = false } = Astro.props;

// Derive a soft background for the category badge
const catBgMap: Record<string, string> = {
  "var(--color-primary)": "var(--color-primary-50)",
  "var(--color-secondary)": "var(--color-accent-50)",
  "var(--color-accent)": "var(--color-accent-50)",
  "var(--color-accent-teal)": "var(--color-teal-100)",
};
const categoryBg = catBgMap[categoryColor] ?? "var(--color-surface-2)";
---

<article
  class={`card card-interactive flex flex-col h-full ${featured ? "ring-2 ring-offset-1" : ""}`}
  style={featured ? "ring-color: var(--color-accent);" : ""}
  data-animate={featured ? "animate__zoomIn" : "animate__fadeInUp"}
  data-delay={featured ? "250" : "200"}
>
  <div class="p-5 flex flex-col h-full">
    <!-- Top row: category badge + featured badge -->
    <div class="flex items-start justify-between gap-2 mb-4">
      <span class="tag text-xs" style={`background: ${categoryBg}; color: ${categoryColor};`}>
        {category}
      </span>
      {
        featured && (
          <span class="tag text-xs" style="background: var(--color-accent); color: var(--color-on-accent);" aria-label="Fremhævet ressource">
            ★ Fremhævet
          </span>
        )
      }
    </div>

    <!-- Icon -->
    <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3 text-xl" style="background: var(--color-surface-2);" aria-hidden="true">
      {icon}
    </div>

    <!-- Title -->
    <h3 class="font-bold text-base leading-snug mb-2" style="font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.03em;">
      {
        href ? (
          <a href={href} class="hover:underline underline-offset-2 focus-visible:underline" style="color: inherit;">
            {title}
          </a>
        ) : (
          title
        )
      }
    </h3>

    <!-- Description -->
    <p class="text-sm leading-relaxed flex-1 mb-4" style="color: var(--color-text-muted); font-family: var(--font-body);">
      {description}
    </p>

    <!-- Tags -->
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4" aria-label="Emner">
          {tags.map((tag) => (
            <span
              class="tag text-xs"
              style="background: var(--color-surface-2); color: var(--color-text-subtle); border: 1px solid var(--color-border);"
            >
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- Link -->
    {
      href && (
        <a
          href={href}
          class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest transition-all hover:gap-2.5 mt-auto"
          style="color: var(--color-primary); font-family: var(--font-body); letter-spacing: 0.06em;"
          aria-label={`Læs mere om ${title}`}
        >
          Læs mere
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )
    }
  </div>
</article>
