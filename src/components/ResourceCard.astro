---
interface Props {
  title: string;
  description: string;
  category: string;
  categoryColor?: string;
  href?: string;
  icon?: string;
  tags?: string[];
  featured?: boolean;
}

const {
  title,
  description,
  category,
  categoryColor = 'var(--color-primary)',
  href,
  icon = '📄',
  tags = [],
  featured = false,
} = Astro.props;

const categoryBg = categoryColor === 'var(--color-primary)'
  ? 'var(--color-primary-50)'
  : categoryColor === 'var(--color-secondary)'
    ? 'var(--color-secondary-50)'
    : 'var(--color-surface-2)';
---

<article
  class={`card card-interactive flex flex-col h-full ${featured ? 'ring-2' : ''}`}
  style={featured ? `ring-color: var(--color-primary);` : ''}
>
  <div class="p-5 flex flex-col h-full">
    <!-- Category badge + icon -->
    <div class="flex items-start justify-between mb-4">
      <span
        class="tag text-xs font-semibold"
        style={`background: ${categoryBg}; color: ${categoryColor};`}
      >
        {category}
      </span>
      {featured && (
        <span
          class="tag text-xs font-medium"
          style="background: var(--color-accent-amber); color: white; opacity: 0.9;"
          aria-label="Fremhævet ressource"
        >
          ★ Fremhævet
        </span>
      )}
    </div>

    <!-- Icon -->
    <div
      class="w-10 h-10 rounded-xl flex items-center justify-center mb-3 text-xl"
      style="background: var(--color-surface-2);"
      aria-hidden="true"
    >
      {icon}
    </div>

    <!-- Title -->
    <h3 class="font-semibold text-base leading-snug mb-2" style="color: var(--color-text);">
      {href ? (
        <a
          href={href}
          class="hover:underline underline-offset-2 focus-visible:underline"
          style="color: inherit;"
        >
          {title}
        </a>
      ) : title}
    </h3>

    <!-- Description -->
    <p class="text-sm leading-relaxed flex-1 mb-4" style="color: var(--color-text-muted);">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4" aria-label="Emner">
        {tags.map((tag) => (
          <span
            class="tag text-xs"
            style="background: var(--color-surface-2); color: var(--color-text-muted);"
          >
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Link -->
    {href && (
      <a
        href={href}
        class="inline-flex items-center gap-1.5 text-sm font-semibold transition-all hover:gap-2.5 mt-auto"
        style="color: var(--color-primary);"
        aria-label={`Læs mere om ${title}`}
      >
        Læs mere
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    )}
  </div>
</article>
