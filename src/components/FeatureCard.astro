---
interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
  color?: "primary" | "accent" | "teal-dark" | "amber";
}

const { title, description, icon, href, color = "primary" } = Astro.props;

const colorMap = {
  primary: {
    iconBg: "var(--color-primary-50)",
    iconText: "var(--color-primary)",
    link: "var(--color-primary)",
  },
  accent: {
    iconBg: "var(--color-accent-50)",
    iconText: "var(--color-accent-dark)",
    link: "var(--color-accent-dark)",
  },
  "teal-dark": {
    iconBg: "var(--color-teal-100)",
    iconText: "var(--color-teal-800)",
    link: "var(--color-teal-700)",
  },
  amber: {
    iconBg: "var(--color-amber-100)",
    iconText: "var(--color-amber-600)",
    link: "var(--color-amber-600)",
  },
};

const c = colorMap[color];
---

<article class="card card-interactive group h-full">
  <div class="p-6 flex flex-col h-full">
    <div
      class="w-12 h-12 rounded-2xl flex items-center justify-center mb-4 text-2xl transition-transform group-hover:scale-110 shrink-0"
      style={`background: ${c.iconBg};`}
      aria-hidden="true"
    >
      {icon}
    </div>

    <h3 class="font-bold text-lg mb-2 leading-snug" style={`font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.03em;`}>
      {title}
    </h3>

    <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted); font-family: var(--font-body);">
      {description}
    </p>

    {
      href && (
        <a
          href={href}
          class="inline-flex items-center gap-1.5 text-sm font-bold mt-4 transition-all hover:gap-2.5 uppercase tracking-wide"
          style={`color: ${c.link}; font-family: var(--font-body); letter-spacing: 0.06em;`}
          aria-label={`Gå til ${title}`}
        >
          Udforsk
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )
    }
  </div>
</article>
