---

---

<!-- Floating accessibility button -->
<button
  id="toolbar-open"
  class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full flex items-center justify-center shadow-xl focus-visible:ring-4 has-tooltip tooltip-up"
  style="background: var(--color-primary); color: var(--color-on-primary); box-shadow: var(--shadow-elevated);"
  aria-label="Åbn tilgængeligheds­værktøjer"
  title="Tilgængelighed"
>
  <svg
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M12 8h.01"></path>
    <path d="M12 12v4"></path>
  </svg>
</button>

<!-- Toolbar panel (slide-in from right) -->
<div
  id="accessibility-toolbar"
  class="fixed top-0 right-0 bottom-0 z-50 w-80 transform translate-x-full transition-transform duration-300 ease-in-out"
  style="background: var(--color-surface); border-left: 1px solid var(--color-border); box-shadow: var(--shadow-elevated);"
  role="dialog"
  aria-label="Tilgængeligheds­indstillinger"
  aria-modal="true"
  aria-hidden="true"
>
  <!-- Inner scroll container, inset from the panel's right edge so its
       scrollbar doesn't sit flush against the page's own scrollbar -->
  <div class="h-full overflow-y-auto overflow-x-hidden" style="width: calc(100% - 6px);">
  <!-- Toolbar header -->
  <div
    class="flex items-center justify-between p-4 border-b sticky top-0 z-10"
    style="background: var(--color-surface); border-color: var(--color-border);"
  >
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-primary-50);" aria-hidden="true">
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="color: var(--color-primary);"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 8h.01"></path>
          <path d="M12 12v4"></path>
        </svg>
      </div>
      <h2 class="font-semibold text-sm" style="color: var(--color-text);">Tilgængelighed</h2>
    </div>
    <button
      id="toolbar-close"
      class="w-8 h-8 rounded-lg flex items-center justify-center transition-all hover:opacity-80 has-tooltip"
      style="color: var(--color-text-muted); background: var(--color-surface-2);"
      aria-label="Luk tilgængeligheds­panel"
      title="Luk panel"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="p-4 space-y-5">
    <!-- Theme -->
    <section aria-labelledby="theme-heading">
      <h3 id="theme-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Tema</h3>
      <div class="grid grid-cols-2 gap-2">
        <button
          class="toolbar-option-btn flex flex-col items-center gap-2 p-3 rounded-xl border-2 transition-all"
          data-action="theme"
          data-value="light"
          aria-pressed="true"
          style="border-color: var(--color-primary); background: var(--color-primary-50);"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            style="color: var(--color-primary);"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
          </svg>
          <span class="text-xs font-medium" style="color: var(--color-text);">Lyst</span>
        </button>
        <button
          class="toolbar-option-btn flex flex-col items-center gap-2 p-3 rounded-xl border-2 transition-all"
          data-action="theme"
          data-value="dark"
          aria-pressed="false"
          style="border-color: var(--color-border); background: var(--color-surface-2);"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            style="color: var(--color-text-muted);"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
          </svg>
          <span class="text-xs font-medium" style="color: var(--color-text);">Mørkt</span>
        </button>
      </div>
    </section>

    <!-- Font size -->
    <section aria-labelledby="font-heading">
      <h3 id="font-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Skriftstørrelse</h3>
      <div class="grid grid-cols-3 gap-2">
        {
          [
            { value: "normal", label: "Normal", size: "text-sm" },
            { value: "large", label: "Stor", size: "text-base" },
            { value: "xlarge", label: "X-Stor", size: "text-lg" },
          ].map(({ value, label, size }) => (
            <button
              class="toolbar-option-btn flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 transition-all"
              data-action="font-size"
              data-value={value}
              aria-pressed={value === "normal" ? "true" : "false"}
              style={
                value === "normal"
                  ? "border-color: var(--color-primary); background: var(--color-primary-50);"
                  : "border-color: var(--color-border); background: var(--color-surface-2);"
              }
            >
              <span class={`font-semibold leading-none ${size}`} style="color: var(--color-text);" aria-hidden="true">
                A
              </span>
              <span class="text-xs" style="color: var(--color-text-muted);">
                {label}
              </span>
            </button>
          ))
        }
      </div>
    </section>

    <!-- Faded colours -->
    <section aria-labelledby="faded-heading">
      <h3 id="faded-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Farver</h3>
      <label class="flex items-center justify-between cursor-pointer p-3 rounded-xl transition-all" style="background: var(--color-surface-2);">
        <div>
          <span class="text-sm font-medium block" style="color: var(--color-text);">Dæmpede farver</span>
          <span class="text-xs" style="color: var(--color-text-muted);">Mindre mættet farvepalette</span>
        </div>
        <div class="relative shrink-0 ml-4">
          <input type="checkbox" id="faded-colors-toggle" class="sr-only" aria-label="Dæmpede farver" />
          <div
            id="faded-track"
            class="w-10 h-6 rounded-full transition-colors duration-200"
            style="background: var(--color-border-strong);"
            aria-hidden="true"
          >
          </div>
          <div
            id="faded-thumb"
            class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white transition-transform duration-200 shadow-sm"
            aria-hidden="true"
          >
          </div>
        </div>
      </label>
    </section>

    <!-- Reduced motion -->
    <section aria-labelledby="motion-heading">
      <h3 id="motion-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Bevægelse</h3>
      <label class="flex items-center justify-between cursor-pointer p-3 rounded-xl transition-all" style="background: var(--color-surface-2);">
        <div>
          <span class="text-sm font-medium block" style="color: var(--color-text);">Reduceret bevægelse</span>
          <span class="text-xs" style="color: var(--color-text-muted);">Slå animationer fra</span>
        </div>
        <div class="relative shrink-0 ml-4">
          <input type="checkbox" id="reduced-motion-toggle" class="sr-only" aria-label="Reduceret bevægelse" />
          <div
            id="toggle-track"
            class="w-10 h-6 rounded-full transition-colors duration-200"
            style="background: var(--color-border-strong);"
            aria-hidden="true"
          >
          </div>
          <div
            id="toggle-thumb"
            class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white transition-transform duration-200 shadow-sm"
            aria-hidden="true"
          >
          </div>
        </div>
      </label>
    </section>

    <!-- Reading font -->
    <section aria-labelledby="reading-font-heading">
      <h3 id="reading-font-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">
        Læseskrift
      </h3>
      <div class="grid grid-cols-2 gap-2">
        {
          [
            { value: "normal",   label: "Standard", preview: "Aa" },
            { value: "atkinson", label: "Atkinson",  preview: "Aa" },
          ].map(({ value, label, preview }) => (
            <button
              class="reading-font-btn flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 transition-all"
              data-font={value}
              aria-pressed={value === "normal" ? "true" : "false"}
              style={
                value === "normal"
                  ? "border-color: var(--color-primary); background: var(--color-primary-50);"
                  : "border-color: var(--color-border); background: var(--color-surface-2);"
              }
            >
              <span
                class="font-semibold leading-none text-base font-preview"
                style={`color: var(--color-text); font-family: ${value === "atkinson" ? "var(--font-reading)" : "var(--font-body)"};`}
                aria-hidden="true"
              >
                {preview}
              </span>
              <span class="text-xs text-center leading-tight" style="color: var(--color-text-muted);">
                {label}
              </span>
            </button>
          ))
        }
      </div>
    </section>

    <!-- Clutter-free / fokus-tilstand -->
    <section aria-labelledby="clutter-heading">
      <h3 id="clutter-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Layout</h3>
      <label class="flex items-center justify-between cursor-pointer p-3 rounded-xl transition-all" style="background: var(--color-surface-2);">
        <div>
          <span class="text-sm font-medium block" style="color: var(--color-text);">Fokustilstand</span>
          <span class="text-xs" style="color: var(--color-text-muted);">Fjern dekorative ekstra sektioner</span>
        </div>
        <div class="relative shrink-0 ml-4">
          <input type="checkbox" id="clutter-free-toggle" class="sr-only" aria-label="Fokustilstand – fjern ekstra sektioner" />
          <div
            id="clutter-track"
            class="w-10 h-6 rounded-full transition-colors duration-200"
            style="background: var(--color-border-strong);"
            aria-hidden="true"
          >
          </div>
          <div
            id="clutter-thumb"
            class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white transition-transform duration-200 shadow-sm"
            aria-hidden="true"
          >
          </div>
        </div>
      </label>
    </section>

    <!-- Reset -->
    <button
      id="reset-preferences"
      class="w-full py-2.5 px-4 rounded-xl text-sm font-medium border transition-all hover:opacity-80"
      style="border-color: var(--color-border); color: var(--color-text-muted); background: transparent;"
      aria-label="Nulstil alle tilgængeligheds­indstillinger"
    >
      Nulstil indstillinger
    </button>

    <!-- Info -->
    <div class="p-3 rounded-xl" style="background: var(--color-primary-50);">
      <p class="text-xs leading-relaxed" style="color: var(--color-primary);">
        Dine præferencer gemmes lokalt på din enhed og huskes næste gang du besøger siden.
      </p>
    </div>
  </div>
  </div>
</div>

<!-- Backdrop -->
<div id="toolbar-backdrop" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.3);" aria-hidden="true"></div>

<script>
  const toolbar = document.getElementById("accessibility-toolbar");
  const openBtn = document.getElementById("toolbar-open");
  const closeBtn = document.getElementById("toolbar-close");
  const backdrop = document.getElementById("toolbar-backdrop");

  function openToolbar() {
    toolbar?.classList.remove("translate-x-full");
    toolbar?.classList.add("translate-x-0");
    toolbar?.setAttribute("aria-hidden", "false");
    backdrop?.classList.remove("hidden");
    closeBtn?.focus();
  }

  function closeToolbar() {
    toolbar?.classList.add("translate-x-full");
    toolbar?.classList.remove("translate-x-0");
    toolbar?.setAttribute("aria-hidden", "true");
    backdrop?.classList.add("hidden");
    openBtn?.focus();
  }

  openBtn?.addEventListener("click", openToolbar);
  closeBtn?.addEventListener("click", closeToolbar);
  backdrop?.addEventListener("click", closeToolbar);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !toolbar?.classList.contains("translate-x-full")) {
      closeToolbar();
    }
  });

  // ── UI sync functions (read state → update own UI only) ─────
  function syncThemeButtons() {
    const theme = document.documentElement.getAttribute("data-theme") ?? "light";
    document.querySelectorAll('[data-action="theme"]').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const active = el.dataset.value === theme;
      el.setAttribute("aria-pressed", String(active));
      el.style.borderColor = active ? "var(--color-primary)" : "var(--color-border)";
      el.style.background = active ? "var(--color-primary-50)" : "var(--color-surface-2)";
    });
  }

  function syncFontButtons() {
    const size = document.documentElement.getAttribute("data-font-size") ?? "normal";
    document.querySelectorAll('[data-action="font-size"]').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const active = el.dataset.value === size;
      el.setAttribute("aria-pressed", String(active));
      el.style.borderColor = active ? "var(--color-primary)" : "var(--color-border)";
      el.style.background = active ? "var(--color-primary-50)" : "var(--color-surface-2)";
    });
  }

  function syncMotionToggle() {
    const on = document.documentElement.getAttribute("data-reduced-motion") === "true";
    const toggle = document.getElementById("reduced-motion-toggle") as HTMLInputElement;
    const track = document.getElementById("toggle-track");
    const thumb = document.getElementById("toggle-thumb");
    if (toggle) toggle.checked = on;
    if (track) track.style.background = on ? "var(--color-primary)" : "var(--color-border-strong)";
    if (thumb) thumb.style.transform = on ? "translateX(16px)" : "translateX(0)";
  }

  function syncReadingFont() {
    const current = document.documentElement.getAttribute("data-reading-font") ?? "normal";
    document.querySelectorAll(".reading-font-btn").forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const active = el.dataset.font === current;
      el.setAttribute("aria-pressed", String(active));
      el.style.borderColor = active ? "var(--color-primary)" : "var(--color-border)";
      el.style.background = active ? "var(--color-primary-50)" : "var(--color-surface-2)";
    });
  }

  function applyReadingFont(value: string) {
    document.documentElement.setAttribute("data-reading-font", value);
    localStorage.setItem("ag-reading-font", value);
  }

  function syncFadedToggle() {
    const on = document.documentElement.getAttribute("data-colors") === "faded";
    const toggle = document.getElementById("faded-colors-toggle") as HTMLInputElement;
    const track = document.getElementById("faded-track");
    const thumb = document.getElementById("faded-thumb");
    if (toggle) toggle.checked = on;
    if (track) track.style.background = on ? "var(--color-primary)" : "var(--color-border-strong)";
    if (thumb) thumb.style.transform = on ? "translateX(16px)" : "translateX(0)";
  }

  function syncClutterFreeToggle() {
    const on = document.documentElement.getAttribute("data-clutter-free") === "true";
    const toggle = document.getElementById("clutter-free-toggle") as HTMLInputElement;
    const track = document.getElementById("clutter-track");
    const thumb = document.getElementById("clutter-thumb");
    if (toggle) toggle.checked = on;
    if (track) track.style.background = on ? "var(--color-primary)" : "var(--color-border-strong)";
    if (thumb) thumb.style.transform = on ? "translateX(16px)" : "translateX(0)";
  }

  // ── MutationObserver — reacts to changes from ANY component ──
  new MutationObserver(() => {
    syncThemeButtons();
    syncFontButtons();
    syncMotionToggle();
    syncFadedToggle();
    syncClutterFreeToggle();
    syncReadingFont();
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme", "data-font-size", "data-reduced-motion", "data-colors", "data-clutter-free", "data-reading-font"],
  });

  // ── Event handlers — only set state, observer handles UI ─────
  document.querySelectorAll('[data-action="theme"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "light";
      document.documentElement.setAttribute("data-theme", value);
      localStorage.setItem("ag-theme", value);
    });
  });

  document.querySelectorAll('[data-action="font-size"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "normal";
      document.documentElement.setAttribute("data-font-size", value);
      localStorage.setItem("ag-font-size", value);
    });
  });

  const motionToggle = document.getElementById("reduced-motion-toggle") as HTMLInputElement;
  motionToggle?.addEventListener("change", () => {
    document.documentElement.setAttribute("data-reduced-motion", String(motionToggle.checked));
    localStorage.setItem("ag-reduced-motion", String(motionToggle.checked));
  });

  document.querySelectorAll(".reading-font-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.font ?? "normal";
      applyReadingFont(value);
    });
  });

  const fadedToggle = document.getElementById("faded-colors-toggle") as HTMLInputElement;
  fadedToggle?.addEventListener("change", () => {
    document.documentElement.setAttribute("data-colors", fadedToggle.checked ? "faded" : "normal");
    localStorage.setItem("ag-faded-colors", String(fadedToggle.checked));
  });

  const clutterToggle = document.getElementById("clutter-free-toggle") as HTMLInputElement;
  clutterToggle?.addEventListener("change", () => {
    document.documentElement.setAttribute("data-clutter-free", String(clutterToggle.checked));
    localStorage.setItem("ag-clutter-free", String(clutterToggle.checked));
  });

  // ── Reset ────────────────────────────────────────────────────
  document.getElementById("reset-preferences")?.addEventListener("click", () => {
    ["ag-theme", "ag-font-size", "ag-reduced-motion", "ag-reading-font", "ag-faded-colors", "ag-clutter-free"].forEach((k) =>
      localStorage.removeItem(k),
    );
    document.documentElement.setAttribute("data-theme", "light");
    document.documentElement.setAttribute("data-font-size", "normal");
    document.documentElement.setAttribute("data-reduced-motion", "false");
    document.documentElement.setAttribute("data-colors", "normal");
    document.documentElement.setAttribute("data-clutter-free", "false");
    document.documentElement.setAttribute("data-reading-font", "normal");
  });

  // ── Initial sync ─────────────────────────────────────────────
  const savedClutterFree = localStorage.getItem("ag-clutter-free") === "true";
  if (savedClutterFree) document.documentElement.setAttribute("data-clutter-free", "true");
  syncThemeButtons();
  syncFontButtons();
  syncMotionToggle();
  syncFadedToggle();
  syncClutterFreeToggle();
</script>
