---

---

<!-- Floating accessibility button -->
<button
  id="toolbar-open"
  class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full flex items-center justify-center shadow-lg transition-all hover:scale-110 focus-visible:ring-4"
  style="background: var(--color-primary); color: var(--color-on-primary); box-shadow: var(--shadow-elevated);"
  aria-label="Åbn tilgængeligheds­værktøjer"
  title="Tilgængeligheds­indstillinger"
>
  <svg
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M12 8h.01"></path>
    <path d="M12 12v4"></path>
  </svg>
</button>

<!-- Toolbar panel (slide-in from right) -->
<div
  id="accessibility-toolbar"
  class="fixed top-0 right-0 bottom-0 z-50 w-80 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
  style="background: var(--color-surface); border-left: 1px solid var(--color-border); box-shadow: var(--shadow-elevated);"
  role="dialog"
  aria-label="Tilgængeligheds­indstillinger"
  aria-modal="true"
  aria-hidden="true"
>
  <!-- Toolbar header -->
  <div
    class="flex items-center justify-between p-4 border-b sticky top-0 z-10"
    style="background: var(--color-surface); border-color: var(--color-border);"
  >
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-primary-50);" aria-hidden="true">
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="color: var(--color-primary);"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 8h.01"></path>
          <path d="M12 12v4"></path>
        </svg>
      </div>
      <h2 class="font-semibold text-sm" style="color: var(--color-text);">Tilgængelighed</h2>
    </div>
    <button
      id="toolbar-close"
      class="w-8 h-8 rounded-lg flex items-center justify-center transition-all hover:opacity-80"
      style="color: var(--color-text-muted); background: var(--color-surface-2);"
      aria-label="Luk tilgængeligheds­panel"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="p-4 space-y-5">
    <!-- Theme -->
    <section aria-labelledby="theme-heading">
      <h3 id="theme-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Tema</h3>
      <div class="grid grid-cols-2 gap-2">
        <button
          class="toolbar-option-btn flex flex-col items-center gap-2 p-3 rounded-xl border-2 transition-all"
          data-action="theme"
          data-value="light"
          aria-pressed="true"
          style="border-color: var(--color-primary); background: var(--color-primary-50);"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            style="color: var(--color-primary);"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
          </svg>
          <span class="text-xs font-medium" style="color: var(--color-text);">Lyst</span>
        </button>
        <button
          class="toolbar-option-btn flex flex-col items-center gap-2 p-3 rounded-xl border-2 transition-all"
          data-action="theme"
          data-value="dark"
          aria-pressed="false"
          style="border-color: var(--color-border); background: var(--color-surface-2);"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            style="color: var(--color-text-muted);"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
          </svg>
          <span class="text-xs font-medium" style="color: var(--color-text);">Mørkt</span>
        </button>
      </div>
    </section>

    <!-- Font size -->
    <section aria-labelledby="font-heading">
      <h3 id="font-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Skriftstørrelse</h3>
      <div class="grid grid-cols-3 gap-2">
        {
          [
            { value: "normal", label: "Normal", size: "text-sm" },
            { value: "large", label: "Stor", size: "text-base" },
            { value: "xlarge", label: "X-Stor", size: "text-lg" },
          ].map(({ value, label, size }) => (
            <button
              class="toolbar-option-btn flex flex-col items-center gap-1.5 p-3 rounded-xl border-2 transition-all"
              data-action="font-size"
              data-value={value}
              aria-pressed={value === "normal" ? "true" : "false"}
              style={
                value === "normal"
                  ? "border-color: var(--color-primary); background: var(--color-primary-50);"
                  : "border-color: var(--color-border); background: var(--color-surface-2);"
              }
            >
              <span class={`font-semibold leading-none ${size}`} style="color: var(--color-text);" aria-hidden="true">
                A
              </span>
              <span class="text-xs" style="color: var(--color-text-muted);">
                {label}
              </span>
            </button>
          ))
        }
      </div>
    </section>

    <!-- Reduced motion -->
    <section aria-labelledby="motion-heading">
      <h3 id="motion-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">Bevægelse</h3>
      <label class="flex items-center justify-between cursor-pointer p-3 rounded-xl transition-all" style="background: var(--color-surface-2);">
        <div>
          <span class="text-sm font-medium block" style="color: var(--color-text);">Reduceret bevægelse</span>
          <span class="text-xs" style="color: var(--color-text-muted);">Slå animationer fra</span>
        </div>
        <div class="relative flex-shrink-0 ml-4">
          <input type="checkbox" id="reduced-motion-toggle" class="sr-only" aria-label="Reduceret bevægelse" />
          <div
            id="toggle-track"
            class="w-10 h-6 rounded-full transition-colors duration-200"
            style="background: var(--color-border-strong);"
            aria-hidden="true"
          >
          </div>
          <div
            id="toggle-thumb"
            class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white transition-transform duration-200 shadow-sm"
            aria-hidden="true"
          >
          </div>
        </div>
      </label>
    </section>

    <!-- Reading font -->
    <section aria-labelledby="reading-font-heading">
      <h3 id="reading-font-heading" class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-text-subtle);">
        Læseskrift
      </h3>
      <label class="flex items-center justify-between cursor-pointer p-3 rounded-xl transition-all" style="background: var(--color-surface-2);">
        <div>
          <span class="text-sm font-medium block" style="color: var(--color-text);">Atkinson Hyperlegible</span>
          <span class="text-xs" style="color: var(--color-text-muted);">Optimeret til læsbarhed</span>
        </div>
        <div class="relative flex-shrink-0 ml-4">
          <input type="checkbox" id="reading-font-toggle" class="sr-only" aria-label="Brug læseskrift" />
          <div
            id="reading-track"
            class="w-10 h-6 rounded-full transition-colors duration-200"
            style="background: var(--color-border-strong);"
            aria-hidden="true"
          >
          </div>
          <div
            id="reading-thumb"
            class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white transition-transform duration-200 shadow-sm"
            aria-hidden="true"
          >
          </div>
        </div>
      </label>
    </section>

    <!-- Reset -->
    <button
      id="reset-preferences"
      class="w-full py-2.5 px-4 rounded-xl text-sm font-medium border transition-all hover:opacity-80"
      style="border-color: var(--color-border); color: var(--color-text-muted); background: transparent;"
      aria-label="Nulstil alle tilgængeligheds­indstillinger"
    >
      Nulstil indstillinger
    </button>

    <!-- Info -->
    <div class="p-3 rounded-xl" style="background: var(--color-primary-50);">
      <p class="text-xs leading-relaxed" style="color: var(--color-primary);">
        Dine præferencer gemmes lokalt på din enhed og huskes næste gang du besøger siden.
      </p>
    </div>
  </div>
</div>

<!-- Backdrop -->
<div id="toolbar-backdrop" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.3);" aria-hidden="true"></div>

<script>
  const toolbar = document.getElementById("accessibility-toolbar");
  const openBtn = document.getElementById("toolbar-open");
  const closeBtn = document.getElementById("toolbar-close");
  const backdrop = document.getElementById("toolbar-backdrop");

  function openToolbar() {
    toolbar?.classList.remove("translate-x-full");
    toolbar?.classList.add("translate-x-0");
    toolbar?.setAttribute("aria-hidden", "false");
    backdrop?.classList.remove("hidden");
    closeBtn?.focus();
    document.body.style.overflow = "hidden";
  }

  function closeToolbar() {
    toolbar?.classList.add("translate-x-full");
    toolbar?.classList.remove("translate-x-0");
    toolbar?.setAttribute("aria-hidden", "true");
    backdrop?.classList.add("hidden");
    document.body.style.overflow = "";
    openBtn?.focus();
  }

  openBtn?.addEventListener("click", openToolbar);
  closeBtn?.addEventListener("click", closeToolbar);
  backdrop?.addEventListener("click", closeToolbar);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !toolbar?.classList.contains("translate-x-full")) {
      closeToolbar();
    }
  });

  // Theme buttons
  function updateThemeButtons(theme: string) {
    document.querySelectorAll('[data-action="theme"]').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const isActive = el.dataset.value === theme;
      el.setAttribute("aria-pressed", String(isActive));
      el.style.borderColor = isActive ? "var(--color-primary)" : "var(--color-border)";
      el.style.background = isActive ? "var(--color-primary-50)" : "var(--color-surface-2)";
    });
    // Also update Navbar icons
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");
    iconSun?.classList.toggle("hidden", theme !== "dark");
    iconMoon?.classList.toggle("hidden", theme === "dark");
  }

  document.querySelectorAll('[data-action="theme"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "light";
      document.documentElement.setAttribute("data-theme", value);
      localStorage.setItem("ag-theme", value);
      updateThemeButtons(value);
    });
  });

  // Font size buttons
  function updateFontButtons(size: string) {
    document.querySelectorAll('[data-action="font-size"]').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const isActive = el.dataset.value === size;
      el.setAttribute("aria-pressed", String(isActive));
      el.style.borderColor = isActive ? "var(--color-primary)" : "var(--color-border)";
      el.style.background = isActive ? "var(--color-primary-50)" : "var(--color-surface-2)";
    });
  }

  document.querySelectorAll('[data-action="font-size"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = (btn as HTMLElement).dataset.value ?? "normal";
      document.documentElement.setAttribute("data-font-size", value);
      localStorage.setItem("ag-font-size", value);
      updateFontButtons(value);
    });
  });

  // Reduced motion toggle
  const motionToggle = document.getElementById("reduced-motion-toggle") as HTMLInputElement;
  const motionTrack = document.getElementById("toggle-track");
  const motionThumb = document.getElementById("toggle-thumb");

  function updateMotionToggle(enabled: boolean) {
    if (motionToggle) motionToggle.checked = enabled;
    if (motionTrack) motionTrack.style.background = enabled ? "var(--color-primary)" : "var(--color-border-strong)";
    if (motionThumb) motionThumb.style.transform = enabled ? "translateX(16px)" : "translateX(0)";
  }

  motionToggle?.addEventListener("change", () => {
    const enabled = motionToggle.checked;
    document.documentElement.setAttribute("data-reduced-motion", String(enabled));
    localStorage.setItem("ag-reduced-motion", String(enabled));
    updateMotionToggle(enabled);
  });

  // Reading font toggle
  const readingToggle = document.getElementById("reading-font-toggle") as HTMLInputElement;
  const readingTrack = document.getElementById("reading-track");
  const readingThumb = document.getElementById("reading-thumb");

  function updateReadingFont(enabled: boolean) {
    if (readingToggle) readingToggle.checked = enabled;
    if (readingTrack) readingTrack.style.background = enabled ? "var(--color-primary)" : "var(--color-border-strong)";
    if (readingThumb) readingThumb.style.transform = enabled ? "translateX(16px)" : "translateX(0)";
    document.body.style.fontFamily = enabled ? "var(--font-reading)" : "var(--font-sans)";
    localStorage.setItem("ag-reading-font", String(enabled));
  }

  readingToggle?.addEventListener("change", () => {
    updateReadingFont(readingToggle.checked);
  });

  // Reset preferences
  document.getElementById("reset-preferences")?.addEventListener("click", () => {
    localStorage.removeItem("ag-theme");
    localStorage.removeItem("ag-font-size");
    localStorage.removeItem("ag-reduced-motion");
    localStorage.removeItem("ag-reading-font");

    document.documentElement.setAttribute("data-theme", "light");
    document.documentElement.setAttribute("data-font-size", "normal");
    document.documentElement.setAttribute("data-reduced-motion", "false");
    document.body.style.fontFamily = "";

    updateThemeButtons("light");
    updateFontButtons("normal");
    updateMotionToggle(false);
    updateReadingFont(false);
  });

  // Initialize from saved prefs
  const savedTheme = localStorage.getItem("ag-theme") ?? "light";
  const savedSize = localStorage.getItem("ag-font-size") ?? "normal";
  const savedMotion = localStorage.getItem("ag-reduced-motion") === "true";
  const savedReading = localStorage.getItem("ag-reading-font") === "true";

  updateThemeButtons(savedTheme);
  updateFontButtons(savedSize);
  updateMotionToggle(savedMotion);
  updateReadingFont(savedReading);
</script>
