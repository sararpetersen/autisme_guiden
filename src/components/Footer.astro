---
/* Footer always uses its own dark design — hardcoded values so light/dark
   mode theme variable overrides do not affect it */

const footerLinks = {
  guide: [
    { href: "/hvad-er-autisme", label: "Hvad er Autisme?" },
    { href: "/tilgaengelighed", label: "Tilgængelighed" },
    { href: "/ressourcer", label: "Ressourcer" },
    { href: "/uddannelse", label: "Uddannelse" },
  ],
  support: [
    { href: "/om-os", label: "Om mig" },
    { href: "/om-os#kontakt", label: "Kontakt" },
    { href: "/om-os#vaerdier", label: "Mine værdier" },
  ],
  accessibility: [
    { href: "/tilgaengelighed", label: "Tilgængelighedserklæring" },
    { href: "/tilgaengelighed#wcag", label: "WCAG 2.2" },
    { href: "/tilgaengelighed#design", label: "Designprincipper" },
  ],
};

/* Hardcoded footer palette — always dark, WCAG verified:
   #CFFBF4 on #17464A → 7.1:1 ✓ AAA
   #9FF0EC on #17464A → 5.3:1 ✓ AA
   rgba(255,255,255,0.75) on #17464A → ~5.5:1 ✓ AA               */
const F = {
  bg: "#17464A",
  border: "rgba(255,255,255,0.10)",
  heading: "#CFFBF4" /* teal-100 — 7.1:1 on bg ✓ */,
  text: "#9FF0EC" /* teal-200 — 5.3:1 on bg ✓ */,
  textFaint: "rgba(255,255,255,0.55)",
  cardBg: "rgba(255,255,255,0.07)",
  cardBorder: "rgba(255,255,255,0.14)",
  accent: "#F6A010",
};
---

<footer role="contentinfo" class="border-t mt-20" style={`background: ${F.bg}; border-color: ${F.border};`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer grid -->
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5 group" aria-label="AutismeGuiden forsiden">
          <!-- Normal mode: small icon + separate wordmark -->
          <div class="logo-set-normal flex items-center gap-3">
            <img src="/autismeguiden_logo_1-2.png" alt="" width="44" height="44"
              class="h-11 w-auto shrink-0 transition-transform duration-200 group-hover:scale-105"
              aria-hidden="true" />
            <div class="flex flex-col leading-none">
              <span class="font-bold text-base tracking-widest uppercase"
                style={`font-family: var(--font-display); color: ${F.heading}; letter-spacing: 0.08em;`}>Autisme</span>
              <span class="font-bold text-base tracking-widest uppercase"
                style={`font-family: var(--font-display); color: ${F.text}; letter-spacing: 0.08em;`}>Guiden</span>
            </div>
          </div>
          <!-- Faded mode: full combined logo -->
          <img src="/autismeguiden_logo_faded.png" alt="AutismeGuiden"
            width="180" height="59"
            class="logo-set-faded h-11 w-auto shrink-0 transition-transform duration-200 group-hover:scale-105" />
        <p class="text-sm leading-relaxed mb-6" style={`color: ${F.text};`}>
          En åben, tilgængelig platform med information om autisme for alle — autistiske personer, pårørende, fagfolk og lærere.
        </p>
        <div class="flex items-center gap-2">
          <span class="tag" style={`background: ${F.cardBg}; color: ${F.heading}; border: 1px solid ${F.cardBorder};`}> WCAG 2.2 </span>
          <span class="tag" style={`background: ${F.accent}; color: white;`}> Gratis </span>
        </div>
      </div>

      <!-- Guide links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style={`font-family: var(--font-display); color: ${F.heading}; letter-spacing: 0.1em;`}
        >
          Guiden
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.guide.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style={`color: ${F.text};`}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style={`font-family: var(--font-display); color: ${F.heading}; letter-spacing: 0.1em;`}
        >
          Om platformen
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.support.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style={`color: ${F.text};`}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Accessibility links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style={`font-family: var(--font-display); color: ${F.heading}; letter-spacing: 0.1em;`}
        >
          Tilgængelighed
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.accessibility.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style={`color: ${F.text};`}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 p-3 rounded-xl" style={`background: ${F.cardBg}; border: 1px solid ${F.cardBorder};`}>
          <button
            id="open-toolbar-footer"
            class="flex items-center gap-2 text-xs font-semibold w-full cursor-pointer transition-all hover:opacity-80"
            style={`color: ${F.heading}; font-family: var(--font-body);`}
            aria-label="Åbn tilgængeligheds­værktøjer"
          >
            <svg
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 8h.01"></path>
              <path d="M12 12v4"></path>
            </svg>
            Tilgængeligheds­værktøjer
          </button>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3" style={`border-color: ${F.border};`}>
      <p class="text-xs" style={`color: ${F.textFaint};`}>
        &copy; {new Date().getFullYear()} AutismeGuiden. Indhold udgivet under åben licens.
      </p>
      <p class="text-xs" style={`color: ${F.textFaint};`}>Bygget med tilgængelighed i fokus &middot; Dansk</p>
    </div>
  </div>
</footer>

<script>
  document.getElementById("open-toolbar-footer")?.addEventListener("click", () => {
    const toolbar = document.getElementById("accessibility-toolbar");
    const backdrop = document.getElementById("toolbar-backdrop");
    if (toolbar && backdrop) {
      toolbar.classList.remove("translate-x-full");
      toolbar.classList.add("translate-x-0");
      toolbar.setAttribute("aria-hidden", "false");
      backdrop.classList.remove("hidden");
      document.getElementById("toolbar-close")?.focus();
      document.body.style.overflow = "hidden";
    }
  });
</script>
