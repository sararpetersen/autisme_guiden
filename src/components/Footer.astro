---
const footerLinks = {
  guide: [
    { href: "/hvad-er-autisme", label: "Hvad er Autisme?" },
    { href: "/tilgaengelighed", label: "Tilgængelighed" },
    { href: "/ressourcer", label: "Ressourcer" },
    { href: "/uddannelse", label: "Uddannelse" },
  ],
  support: [
    { href: "/om-os", label: "Om mig" },
    { href: "/om-os#kontakt", label: "Kontakt" },
    { href: "/om-os#vaerdier", label: "Mine værdier" },
  ],
  accessibility: [
    { href: "/tilgaengelighed", label: "Tilgængelighedserklæring" },
    { href: "/tilgaengelighed#wcag", label: "WCAG 2.2" },
    { href: "/tilgaengelighed#design", label: "Designprincipper" },
  ],
};
---

<!-- Footer colours are controlled by --footer-* CSS variables defined in
     global.css, so dark mode and faded mode update automatically. -->
<footer role="contentinfo" class="border-t mt-20" style="background: var(--footer-bg); border-color: var(--footer-border);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5 group" aria-label="AutismeGuiden forsiden">
          <div class="logo-set-normal contents">
            <img
              src="/autismeguiden_logo.webp"
              alt="AutismeGuiden"
              width="180"
              height="59"
              class="h-11 w-auto shrink-0 transition-transform duration-200 group-hover:scale-105"
            />
          </div>
          <div class="logo-set-faded contents">
            <img
              src="/autismeguiden_logo_faded.webp"
              alt="AutismeGuiden"
              width="180"
              height="59"
              class="h-11 w-auto shrink-0 transition-transform duration-200 group-hover:scale-105"
            />
          </div>
        </a>
        <p class="text-sm leading-relaxed mb-6" style="color: var(--footer-text);">
          En åben, tilgængelig platform med information om autisme og neurodivergens – for neurodivergente, pårørende, fagfolk og lærere.
        </p>
        <div class="flex items-center gap-2">
          <span class="tag" style="background: var(--footer-card-bg); color: var(--footer-heading); border: 1px solid var(--footer-card-border);"
            >WCAG 2.2</span
          >
          <span class="tag tag-gratis" style="background: var(--color-accent); color: white;">Gratis</span>
        </div>
      </div>

      <!-- Guide links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: var(--font-display); color: var(--footer-heading); letter-spacing: 0.1em;"
        >
          Guiden
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.guide.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style="color: var(--footer-text);">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: var(--font-display); color: var(--footer-heading); letter-spacing: 0.1em;"
        >
          Om platformen
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.support.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style="color: var(--footer-text);">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Accessibility links -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: var(--font-display); color: var(--footer-heading); letter-spacing: 0.1em;"
        >
          Tilgængelighed
        </h3>
        <ul class="space-y-2.5" role="list">
          {
            footerLinks.accessibility.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2" style="color: var(--footer-text);">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 p-3 rounded-xl" style="background: var(--footer-card-bg); border: 1px solid var(--footer-card-border);">
          <button
            id="open-toolbar-footer"
            class="flex items-center gap-2 text-xs font-semibold w-full cursor-pointer transition-all hover:opacity-80"
            style="color: var(--footer-heading); font-family: var(--font-body);"
            aria-label="Åbn tilgængeligheds­værktøjer"
          >
            <svg
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 8h.01"></path>
              <path d="M12 12v4"></path>
            </svg>
            Tilgængeligheds­værktøjer
          </button>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3" style="border-color: var(--footer-border);">
      <p class="text-xs" style="color: var(--footer-text-faint);">
        &copy; {new Date().getFullYear()} AutismeGuiden. Indhold udgivet under åben licens.
      </p>
      <p class="text-xs" style="color: var(--footer-text-faint);">Bygget med tilgængelighed i fokus &middot; Dansk</p>
    </div>
  </div>
</footer>

<script>
  document.getElementById("open-toolbar-footer")?.addEventListener("click", () => {
    const toolbar = document.getElementById("accessibility-toolbar");
    const backdrop = document.getElementById("toolbar-backdrop");
    if (toolbar && backdrop) {
      toolbar.classList.remove("translate-x-full");
      toolbar.classList.add("translate-x-0");
      toolbar.setAttribute("aria-hidden", "false");
      backdrop.classList.remove("hidden");
      document.getElementById("toolbar-close")?.focus();
      document.body.style.overflow = "hidden";
    }
  });
</script>
