---
const footerLinks = {
  guide: [
    { href: '/hvad-er-autisme', label: 'Hvad er Autisme?' },
    { href: '/tilgaengelighed', label: 'Tilgængelighed' },
    { href: '/ressourcer', label: 'Ressourcer' },
    { href: '/uddannelse', label: 'Uddannelse' },
  ],
  support: [
    { href: '/om-os', label: 'Om Os' },
    { href: '/om-os#kontakt', label: 'Kontakt' },
    { href: '/om-os#vaerdier', label: 'Vores Værdier' },
  ],
  accessibility: [
    { href: '/tilgaengelighed', label: 'Tilgængeligheds­erklæring' },
    { href: '/tilgaengelighed#wcag', label: 'WCAG 2.2' },
    { href: '/tilgaengelighed#design', label: 'Design­principper' },
  ],
};
---

<footer
  role="contentinfo"
  class="border-t mt-20"
  style="background: var(--color-primary-dark); border-color: var(--color-primary-mid); color: var(--color-teal-200);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5 group" aria-label="AutismeGuiden forsiden">
          <!-- Compact logo mark -->
          <svg width="38" height="38" viewBox="0 0 40 40" fill="none" aria-hidden="true"
            class="transition-transform group-hover:scale-105">
            <polygon points="20,1 23,14 17,14" fill="#37CBCA"/>
            <polygon points="20,39 17,26 23,26" fill="#37CBCA"/>
            <polygon points="1,20 14,17 14,23" fill="#9FF0EC"/>
            <polygon points="39,20 26,23 26,17" fill="#9FF0EC"/>
            <circle cx="20" cy="20" r="12" fill="#17464A"/>
            <path d="M8 20 L8 10 Q8 8 10 8 L20 8 L20 12 Q20 14 18 14 Q16 14 16 16 Q16 18 18 18 Q20 18 20 20 L8 20 Z" fill="#37CBCA"/>
            <circle cx="20" cy="15" r="2.2" fill="#37CBCA"/>
            <path d="M20 8 L30 8 Q32 8 32 10 L32 20 L28 20 Q26 20 26 18 Q26 16 24 16 Q22 16 22 18 Q22 20 20 20 L20 8 Z" fill="#9FF0EC"/>
            <circle cx="25" cy="20" r="2.2" fill="#9FF0EC"/>
            <path d="M32 20 L32 30 Q32 32 30 32 L20 32 L20 28 Q20 26 22 26 Q24 26 24 24 Q24 22 22 22 Q20 22 20 20 L32 20 Z" fill="#F6A010"/>
            <circle cx="20" cy="25" r="2.2" fill="#F6A010"/>
            <path d="M8 20 L20 20 L20 22 Q20 24 18 24 Q16 24 16 26 Q16 28 18 28 Q20 28 20 32 L10 32 Q8 32 8 30 L8 20 Z" fill="#F8BC29"/>
            <circle cx="15" cy="20" r="2.2" fill="#F8BC29"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="font-bold text-base tracking-widest uppercase" style="font-family: var(--font-display); color: var(--color-teal-200); letter-spacing: 0.08em;">Autisme</span>
            <span class="font-bold text-base tracking-widest uppercase" style="font-family: var(--font-display); color: var(--color-teal-300); letter-spacing: 0.08em;">Guiden</span>
          </div>
        </a>
        <p class="text-sm leading-relaxed mb-6" style="color: var(--color-teal-300); opacity: 0.85;">
          En åben, tilgængelig platform med information om autisme for alle — autistiske personer, pårørende, fagfolk og lærere.
        </p>
        <div class="flex items-center gap-2">
          <span class="tag" style="background: rgb(255 255 255 / 0.08); color: var(--color-teal-200); border: 1px solid rgb(255 255 255 / 0.15);">
            WCAG 2.2
          </span>
          <span class="tag" style="background: var(--color-accent); color: white;">
            Gratis
          </span>
        </div>
      </div>

      <!-- Guide links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4" style="font-family: var(--font-display); color: var(--color-teal-300); letter-spacing: 0.1em;">
          Guiden
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerLinks.guide.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2"
                style="color: var(--color-teal-200); opacity: 0.8;">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4" style="font-family: var(--font-display); color: var(--color-teal-300); letter-spacing: 0.1em;">
          Om platformen
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerLinks.support.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2"
                style="color: var(--color-teal-200); opacity: 0.8;">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Accessibility links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4" style="font-family: var(--font-display); color: var(--color-teal-300); letter-spacing: 0.1em;">
          Tilgængelighed
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerLinks.accessibility.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm transition-all hover:opacity-100 hover:underline underline-offset-2"
                style="color: var(--color-teal-200); opacity: 0.8;">{label}</a>
            </li>
          ))}
        </ul>

        <div class="mt-6 p-3 rounded-xl" style="background: rgb(255 255 255 / 0.07); border: 1px solid rgb(255 255 255 / 0.12);">
          <button
            id="open-toolbar-footer"
            class="flex items-center gap-2 text-xs font-semibold w-full transition-all hover:opacity-80"
            style="color: var(--color-teal-300); font-family: var(--font-body);"
            aria-label="Åbn tilgængeligheds­værktøjer"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 8h.01M11 12h1v4h1"/>
            </svg>
            Tilgængeligheds­værktøjer
          </button>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3"
      style="border-color: rgb(255 255 255 / 0.10);">
      <p class="text-xs" style="color: var(--color-teal-300); opacity: 0.6;">
        &copy; {new Date().getFullYear()} AutismeGuiden. Indhold udgivet under åben licens.
      </p>
      <p class="text-xs" style="color: var(--color-teal-300); opacity: 0.6;">
        Bygget med tilgængelighed i fokus &middot; Dansk
      </p>
    </div>
  </div>
</footer>

<script>
  document.getElementById('open-toolbar-footer')?.addEventListener('click', () => {
    const toolbar = document.getElementById('accessibility-toolbar');
    const backdrop = document.getElementById('toolbar-backdrop');
    if (toolbar && backdrop) {
      toolbar.classList.remove('translate-x-full');
      toolbar.classList.add('translate-x-0');
      toolbar.setAttribute('aria-hidden', 'false');
      backdrop.classList.remove('hidden');
      document.getElementById('toolbar-close')?.focus();
      document.body.style.overflow = 'hidden';
    }
  });
</script>
