---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  ariaLabel?: string;
  class?: string;
  fullWidth?: boolean;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  disabled = false,
  ariaLabel,
  class: className = "",
  fullWidth = false,
} = Astro.props;

const sizeClasses = {
  sm: "px-4 py-2 text-sm rounded-lg",
  md: "px-5 py-2.5 text-sm rounded-xl",
  lg: "px-7 py-3.5 text-base rounded-xl",
};

const variantStyles = {
  primary: "background: var(--color-primary); color: var(--color-on-primary, white);",
  secondary: "background: var(--color-secondary); color: var(--color-on-primary, white);",
  outline: "background: transparent; color: var(--color-primary); border: 2px solid var(--color-primary);",
  ghost: "background: var(--color-surface-2); color: var(--color-text);",
};

const baseClasses = `inline-flex items-center justify-center gap-2 font-semibold transition-all duration-150 focus-visible:ring-4 focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed hover:opacity-90 active:scale-[0.98] ${sizeClasses[size]} ${fullWidth ? "w-full" : ""} ${className}`;
---

{
  href ? (
    <a href={href} class={baseClasses} style={variantStyles[variant]} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button type={type} class={baseClasses} style={variantStyles[variant]} disabled={disabled} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
