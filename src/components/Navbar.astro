---
const navLinks = [
  { href: "/", label: "Hjem" },
  { href: "/hvad-er-autisme", label: "Hvad er Autisme?" },
  { href: "/tilgaengelighed", label: "Tilgængelighed" },
  { href: "/ressourcer", label: "Ressourcer" },
  { href: "/uddannelse", label: "Uddannelse" },
  { href: "/om-os", label: "Om mig" },
];

const currentPath = Astro.url.pathname;
---

<header role="banner">
  <nav
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-300"
    style="background: var(--color-surface); border-color: var(--color-border);"
    aria-label="Primær navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-18">
        <!-- ─── Logo ─── -->
        <a href="/" class="flex items-center group shrink-0" aria-label="AutismeGuiden – Gå til forsiden">
          <!-- Normal logos (hidden when faded mode is on) -->
          <div class="logo-set-normal contents">
            <img src="/autismeguiden_logo_1-2.png" alt="AutismeGuiden logo"
              width="40" height="40"
              class="block lg:hidden h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
            <img src="/autismeguiden_logo.png" alt="AutismeGuiden"
              width="180" height="59"
              class="hidden lg:block h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
          </div>
          <!-- Faded logos (shown when faded mode is on) -->
          <div class="logo-set-faded contents">
            <img src="/autismeguiden_logo_1.png" alt="AutismeGuiden logo"
              width="40" height="40"
              class="block lg:hidden h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
            <img src="/autismeguiden_logo_faded.png" alt="AutismeGuiden"
              width="180" height="59"
              class="hidden lg:block h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
          </div>
        </a>

        <!-- ─── Desktop nav links ─── -->
        <div class="hidden lg:flex items-center gap-0.5" role="list">
          {
            navLinks.map(({ href, label }) => {
              const isActive = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
              return (
                <a
                  href={href}
                  class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-150"
                  style={
                    isActive
                      ? "background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);"
                      : "color: var(--color-text-muted); font-family: var(--font-body);"
                  }
                  aria-current={isActive ? "page" : undefined}
                  role="listitem"
                >
                  {label}
                </a>
              );
            })
          }
        </div>

        <!-- ─── Right controls ─── -->
        <div class="flex items-center gap-1.5">
          <!-- Font size toggle -->
          <button
            id="font-size-toggle"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all hover:opacity-80"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border); font-family: var(--font-display); font-weight: 700; font-size: 0.85rem; line-height: 1; letter-spacing: 0;"
            aria-label="Skift skriftstørrelse"
            title="Skift skriftstørrelse"
          >
            <span id="font-size-label" aria-hidden="true">A</span>
          </button>

          <!-- Faded colours toggle -->
          <button
            id="faded-toggle-nav"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all hover:opacity-80"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Dæmpede farver: slået fra"
            title="Dæmp farverne"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a10 10 0 010 20V2z" fill="currentColor" stroke="none" opacity="0.4"/>
            </svg>
          </button>

          <!-- Reduced motion toggle -->
          <button
            id="motion-toggle-nav"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all hover:opacity-80"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Reduceret bevægelse: slået fra"
            title="Slå animationer fra/til"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </button>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all hover:opacity-80"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Skift tema"
            title="Skift mellem lyst og mørkt tema"
          >
            <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
            <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            class="lg:hidden flex flex-col items-center justify-center w-9 h-9 rounded-lg gap-1.5 transition-all"
            style="color: var(--color-text); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Åbn menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span class="block w-5 h-0.5" style="background: currentColor;" id="bar1"></span>
            <span class="block w-5 h-0.5" style="background: currentColor;" id="bar2"></span>
            <span class="block w-4 h-0.5" style="background: currentColor;" id="bar3"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- ─── Mobile menu ─── -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden border-t"
      style="border-color: var(--color-border); background: var(--color-surface);"
      aria-label="Mobilmenu"
    >
      <div class="px-4 py-3 space-y-1">
        {
          navLinks.map(({ href, label }) => {
            const isActive = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class="flex items-center px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
                style={
                  isActive
                    ? "background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);"
                    : "color: var(--color-text-muted); font-family: var(--font-body);"
                }
                aria-current={isActive ? "page" : undefined}
              >
                {label}
              </a>
            );
          })
        }

        <!-- Mobile dark mode -->
        <div class="pt-2 border-t" style="border-color: var(--color-border);">
          <button
            id="theme-toggle-mobile"
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold w-full transition-all hover:opacity-80"
            style="color: var(--color-text-muted); font-family: var(--font-body);"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
            <span id="theme-label-mobile">Skift til mørkt tema</span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed navbar -->
  <div class="h-16 lg:h-18" aria-hidden="true"></div>
</header>

<script>
  // Mobile menu
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  menuToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuToggle.setAttribute("aria-expanded", String(!isOpen));
    menuToggle.setAttribute("aria-label", isOpen ? "Åbn menu" : "Luk menu");
  });

  // Theme
  function updateThemeIcons() {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    document.getElementById("icon-sun")?.classList.toggle("hidden", !isDark);
    document.getElementById("icon-moon")?.classList.toggle("hidden", isDark);
    const mobileLabel = document.getElementById("theme-label-mobile");
    if (mobileLabel) mobileLabel.textContent = isDark ? "Skift til lyst tema" : "Skift til mørkt tema";
  }

  function toggleTheme() {
    const next = document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("ag-theme", next);
    updateThemeIcons();
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
  updateThemeIcons();

  // Font size toggle — cycles normal → large → xlarge → normal
  const fontSizes = ["normal", "large", "xlarge"];
  const fontLabels: Record<string, string> = { normal: "A", large: "A+", xlarge: "A++" };

  function updateFontSizeBtn() {
    const current = document.documentElement.getAttribute("data-font-size") ?? "normal";
    const label = document.getElementById("font-size-label");
    const btn = document.getElementById("font-size-toggle");
    if (label) label.textContent = fontLabels[current] ?? "A";
    if (btn) btn.setAttribute("aria-label", `Skriftstørrelse: ${fontLabels[current] ?? "Normal"}. Klik for at skifte.`);
    const isChanged = current !== "normal";
    if (btn) {
      btn.style.color = isChanged ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = isChanged ? "var(--color-primary)" : "var(--color-border)";
    }
  }

  document.getElementById("font-size-toggle")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-font-size") ?? "normal";
    const next = fontSizes[(fontSizes.indexOf(current) + 1) % fontSizes.length];
    document.documentElement.setAttribute("data-font-size", next);
    localStorage.setItem("ag-font-size", next);
    updateFontSizeBtn();
  });

  updateFontSizeBtn();

  // Reduced motion toggle
  function updateMotionBtn() {
    const enabled = document.documentElement.getAttribute("data-reduced-motion") === "true";
    const btn = document.getElementById("motion-toggle-nav");
    if (btn) {
      btn.style.color = enabled ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = enabled ? "var(--color-primary)" : "var(--color-border)";
      btn.setAttribute("aria-label", `Reduceret bevægelse: ${enabled ? "slået til" : "slået fra"}`);
    }
  }

  document.getElementById("motion-toggle-nav")?.addEventListener("click", () => {
    const enabled = document.documentElement.getAttribute("data-reduced-motion") === "true";
    document.documentElement.setAttribute("data-reduced-motion", String(!enabled));
    localStorage.setItem("ag-reduced-motion", String(!enabled));
    updateMotionBtn();
    // Keep toolbar in sync
    const motionToggle = document.getElementById("reduced-motion-toggle") as HTMLInputElement;
    if (motionToggle) {
      motionToggle.checked = !enabled;
      motionToggle.dispatchEvent(new Event("change"));
    }
  });

  updateMotionBtn();

  // Faded colours toggle
  function updateFadedBtn() {
    const enabled = document.documentElement.getAttribute('data-colors') === 'faded';
    const btn = document.getElementById('faded-toggle-nav');
    if (btn) {
      btn.style.color = enabled ? 'var(--color-primary)' : 'var(--color-text-muted)';
      btn.style.borderColor = enabled ? 'var(--color-primary)' : 'var(--color-border)';
      btn.setAttribute('aria-label', `Dæmpede farver: ${enabled ? 'slået til' : 'slået fra'}`);
    }
    // Keep toolbar toggle in sync
    const toolbarToggle = document.getElementById('faded-colors-toggle') as HTMLInputElement | null;
    if (toolbarToggle) toolbarToggle.checked = enabled;
    const track = document.getElementById('faded-track');
    const thumb = document.getElementById('faded-thumb');
    if (track) track.style.background = enabled ? 'var(--color-primary)' : 'var(--color-border-strong)';
    if (thumb) thumb.style.transform = enabled ? 'translateX(16px)' : 'translateX(0)';
  }

  document.getElementById('faded-toggle-nav')?.addEventListener('click', () => {
    const enabled = document.documentElement.getAttribute('data-colors') === 'faded';
    document.documentElement.setAttribute('data-colors', enabled ? 'normal' : 'faded');
    localStorage.setItem('ag-faded-colors', String(!enabled));
    updateFadedBtn();
  });

  updateFadedBtn();

  // Scroll shadow
  const navbar = document.getElementById("navbar");
  window.addEventListener(
    "scroll",
    () => {
      navbar?.classList.toggle("shadow-sm", window.scrollY > 10);
    },
    { passive: true },
  );
</script>
