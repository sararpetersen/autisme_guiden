---
const navLinks = [
  { href: "/", label: "Hjem" },
  { href: "/hvad-er-autisme", label: "Hvad er Autisme?" },
  { href: "/tilgaengelighed", label: "Tilgængelighed" },
  { href: "/ressourcer", label: "Ressourcer" },
  { href: "/uddannelse", label: "Uddannelse" },
  { href: "/om-os", label: "Om mig" },
];

const currentPath = Astro.url.pathname;
---

<header role="banner">
  <nav
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-300"
    style="background: var(--color-surface); border-color: var(--color-border);"
    aria-label="Primær navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-18">
        <!-- ─── Logo ─── -->
        <a href="/" class="flex items-center group shrink-0" aria-label="AutismeGuiden – Gå til forsiden">
          <!-- Normal logos (hidden when faded mode is on) -->
          <div class="logo-set-normal contents">
            <img src="/autismeguiden_logo_1-2.webp" alt="AutismeGuiden logo"
              width="40" height="40"
              class="block lg:hidden h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
            <img src="/autismeguiden_logo.webp" alt="AutismeGuiden"
              width="180" height="59"
              class="hidden lg:block h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
          </div>
          <!-- Faded logos (shown when faded mode is on) -->
          <div class="logo-set-faded contents">
            <img src="/autismeguiden_logo_1.webp" alt="AutismeGuiden logo"
              width="40" height="40"
              class="block lg:hidden h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
            <img src="/autismeguiden_logo_faded.webp" alt="AutismeGuiden"
              width="180" height="59"
              class="hidden lg:block h-10 w-auto transition-transform duration-200 group-hover:scale-105" />
          </div>
        </a>

        <!-- ─── Desktop nav links ─── -->
        <ul class="hidden lg:flex items-center gap-0.5" role="list">
          {
            navLinks.map(({ href, label }) => {
              const isActive = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
              return (
                <li>
                  <a
                    href={href}
                    class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-150"
                    style={
                      isActive
                        ? "background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);"
                        : "color: var(--color-text-muted); font-family: var(--font-body);"
                    }
                    aria-current={isActive ? "page" : undefined}
                  >
                    {label}
                  </a>
                </li>
              );
            })
          }
        </ul>

        <!-- ─── Right controls ─── -->
        <div class="flex items-center gap-1.5">
          <!-- Font size toggle -->
          <button
            id="font-size-toggle"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all has-tooltip"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Skift skriftstørrelse"
            title="Skriftstørrelse"
          >
            <span id="font-size-label" aria-hidden="true"
              style="font-family: var(--font-body); font-size: 0.85rem; font-weight: 700; line-height: 1; display: block;">A</span>
          </button>

          <!-- Faded colours toggle -->
          <button
            id="faded-toggle-nav"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all has-tooltip"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Dæmpede farver: slået fra"
            title="Dæmpede farver"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a10 10 0 010 20V2z" fill="currentColor" stroke="none" opacity="0.4"/>
            </svg>
          </button>

          <!-- Reduced motion toggle -->
          <button
            id="motion-toggle-nav"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all has-tooltip"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Reduceret bevægelse: slået fra"
            title="Reducér bevægelse"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </button>

          <!-- Fokustilstand toggle -->
          <button
            id="clutter-toggle-nav"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all has-tooltip"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Fokustilstand: slået fra"
            title="Fokustilstand"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 6h16M4 11h10M4 16h6"/>
            </svg>
          </button>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all has-tooltip"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Skift tema"
            title="Skift tema"
          >
            <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
            <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            class="lg:hidden flex flex-col items-center justify-center w-9 h-9 rounded-lg gap-1 transition-all"
            style="color: var(--color-text); background: var(--color-surface-2); border: 1.5px solid var(--color-border-strong);"
            aria-label="Åbn menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span class="block w-3 h-0.5" style="background: currentColor;" id="bar1"></span>
            <span class="block w-3 h-0.5" style="background: currentColor;" id="bar2"></span>
            <span class="block w-2.5 h-0.5" style="background: currentColor;" id="bar3"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- ─── Mobile menu ─── -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden border-t"
      style="border-color: var(--color-border); background: var(--color-surface);"
      aria-label="Mobilmenu"
    >
      <div class="px-4 py-3 space-y-1">
        {
          navLinks.map(({ href, label }) => {
            const isActive = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class="flex items-center px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
                style={
                  isActive
                    ? "background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);"
                    : "color: var(--color-text-subtle); font-family: var(--font-body);"
                }
                aria-current={isActive ? "page" : undefined}
              >
                {label}
              </a>
            );
          })
        }

        <!-- Mobile accessibility controls -->
        <div class="pt-2 border-t" style="border-color: var(--color-border);">
          <p class="px-3 pt-2 pb-1.5 text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-subtle); font-family: var(--font-body);">Tilgængelighed</p>
          <div class="grid grid-cols-2 gap-1.5 px-3 pb-3">
            <!-- Font size -->
            <button
              id="font-size-toggle-mobile"
              class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style="color: var(--color-text-subtle); font-family: var(--font-body); background: var(--color-surface-2);"
              aria-label="Skriftstørrelse: Normal. Klik for at skifte."
            >
              <span id="font-size-label-mobile" aria-hidden="true" style="font-family: var(--font-body); font-size: 0.85rem; font-weight: 700; line-height: 1; display: block;">A</span>
              Skriftstørrelse
            </button>
            <!-- Faded colors -->
            <button
              id="faded-toggle-mobile"
              class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style="color: var(--color-text-subtle); font-family: var(--font-body); background: var(--color-surface-2);"
              aria-label="Dæmpede farver: slået fra"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 2a10 10 0 010 20V2z" fill="currentColor" stroke="none" opacity="0.4"/>
              </svg>
              Dæmpede farver
            </button>
            <!-- Reduced motion -->
            <button
              id="motion-toggle-mobile"
              class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style="color: var(--color-text-subtle); font-family: var(--font-body); background: var(--color-surface-2);"
              aria-label="Reduceret bevægelse: slået fra"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Reducér bevægelse
            </button>
            <!-- Fokustilstand -->
            <button
              id="clutter-toggle-mobile"
              class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style="color: var(--color-text-subtle); font-family: var(--font-body); background: var(--color-surface-2);"
              aria-label="Fokustilstand: slået fra"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 6h16M4 11h10M4 16h6"/>
              </svg>
              Fokustilstand
            </button>
            <!-- Dark/light theme -->
            <button
              id="theme-toggle-mobile"
              class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style="color: var(--color-text-subtle); font-family: var(--font-body); background: var(--color-surface-2);"
              aria-label="Skift til mørkt tema"
            >
              <svg id="icon-moon-mobile" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
              </svg>
              <svg id="icon-sun-mobile" class="w-4 h-4 shrink-0 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="5"></circle>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
              </svg>
              <span id="theme-label-mobile">Mørkt tema</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed navbar -->
  <div class="h-16 lg:h-18" aria-hidden="true"></div>
</header>

<script>
  // ── Mobile menu ──────────────────────────────────────────────
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  menuToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuToggle.setAttribute("aria-expanded", String(!isOpen));
    menuToggle.setAttribute("aria-label", isOpen ? "Åbn menu" : "Luk menu");
  });

  // ── UI sync functions (read state → update own UI only) ──────
  const fontSizes = ["normal", "large", "xlarge"];
  const fontLabels: Record<string, string> = { normal: "A", large: "A+", xlarge: "A++" };

  function syncTheme() {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    // Desktop icons
    document.getElementById("icon-sun")?.classList.toggle("hidden", !isDark);
    document.getElementById("icon-moon")?.classList.toggle("hidden", isDark);
    // Mobile icons
    document.getElementById("icon-sun-mobile")?.classList.toggle("hidden", !isDark);
    document.getElementById("icon-moon-mobile")?.classList.toggle("hidden", isDark);
    // Mobile button active state
    const mobileThemeBtn = document.getElementById("theme-toggle-mobile");
    if (mobileThemeBtn) {
      mobileThemeBtn.setAttribute("aria-label", isDark ? "Skift til lyst tema" : "Skift til mørkt tema");
      mobileThemeBtn.style.color = isDark ? "var(--color-primary)" : "var(--color-text-subtle)";
      mobileThemeBtn.style.background = isDark ? "var(--color-primary-100)" : "var(--color-surface-2)";
    }
    const lbl = document.getElementById("theme-label-mobile");
    if (lbl) lbl.textContent = isDark ? "Lyst tema" : "Mørkt tema";
  }

  function syncFontSize() {
    const cur = document.documentElement.getAttribute("data-font-size") ?? "normal";
    const active = cur !== "normal";
    // Desktop
    const lbl = document.getElementById("font-size-label");
    const btn = document.getElementById("font-size-toggle");
    if (lbl) lbl.textContent = fontLabels[cur] ?? "A";
    if (btn) {
      btn.setAttribute("aria-label", `Skriftstørrelse: ${fontLabels[cur] ?? "Normal"}. Klik for at skifte.`);
      btn.style.color = active ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = active ? "var(--color-primary)" : "var(--color-border-strong)";
    }
    // Mobile
    const mobileLbl = document.getElementById("font-size-label-mobile");
    const mobileBtn = document.getElementById("font-size-toggle-mobile");
    if (mobileLbl) mobileLbl.textContent = fontLabels[cur] ?? "A";
    if (mobileBtn) {
      mobileBtn.setAttribute("aria-label", `Skriftstørrelse: ${fontLabels[cur] ?? "Normal"}. Klik for at skifte.`);
      mobileBtn.style.color = active ? "var(--color-primary)" : "var(--color-text-subtle)";
      mobileBtn.style.background = active ? "var(--color-primary-100)" : "var(--color-surface-2)";
    }
  }

  function syncMotion() {
    const on = document.documentElement.getAttribute("data-reduced-motion") === "true";
    // Desktop
    const btn = document.getElementById("motion-toggle-nav");
    if (btn) {
      btn.style.color = on ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = on ? "var(--color-primary)" : "var(--color-border-strong)";
      btn.setAttribute("aria-label", `Reduceret bevægelse: ${on ? "slået til" : "slået fra"}`);
    }
    // Mobile
    const mobileBtn = document.getElementById("motion-toggle-mobile");
    if (mobileBtn) {
      mobileBtn.style.color = on ? "var(--color-primary)" : "var(--color-text-subtle)";
      mobileBtn.style.background = on ? "var(--color-primary-100)" : "var(--color-surface-2)";
      mobileBtn.setAttribute("aria-label", `Reduceret bevægelse: ${on ? "slået til" : "slået fra"}`);
    }
  }

  function syncFaded() {
    const on = document.documentElement.getAttribute("data-colors") === "faded";
    // Desktop
    const btn = document.getElementById("faded-toggle-nav");
    if (btn) {
      btn.style.color = on ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = on ? "var(--color-primary)" : "var(--color-border-strong)";
      btn.setAttribute("aria-label", `Dæmpede farver: ${on ? "slået til" : "slået fra"}`);
    }
    // Mobile
    const mobileBtn = document.getElementById("faded-toggle-mobile");
    if (mobileBtn) {
      mobileBtn.style.color = on ? "var(--color-primary)" : "var(--color-text-subtle)";
      mobileBtn.style.background = on ? "var(--color-primary-100)" : "var(--color-surface-2)";
      mobileBtn.setAttribute("aria-label", `Dæmpede farver: ${on ? "slået til" : "slået fra"}`);
    }
  }

  function syncClutter() {
    const on = document.documentElement.getAttribute("data-clutter-free") === "true";
    // Desktop
    const btn = document.getElementById("clutter-toggle-nav");
    if (btn) {
      btn.style.color = on ? "var(--color-primary)" : "var(--color-text-muted)";
      btn.style.borderColor = on ? "var(--color-primary)" : "var(--color-border-strong)";
      btn.setAttribute("aria-label", `Fokustilstand: ${on ? "slået til" : "slået fra"}`);
    }
    // Mobile
    const mobileBtn = document.getElementById("clutter-toggle-mobile");
    if (mobileBtn) {
      mobileBtn.style.color = on ? "var(--color-primary)" : "var(--color-text-subtle)";
      mobileBtn.style.background = on ? "var(--color-primary-100)" : "var(--color-surface-2)";
      mobileBtn.setAttribute("aria-label", `Fokustilstand: ${on ? "slået til" : "slået fra"}`);
    }
  }

  // ── MutationObserver — reacts to changes from ANY component ──
  new MutationObserver(() => {
    syncTheme();
    syncFontSize();
    syncMotion();
    syncFaded();
    syncClutter();
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme", "data-font-size", "data-reduced-motion", "data-colors", "data-clutter-free"],
  });

  // ── Click handlers — only set state, observer handles UI ─────
  function toggleTheme() {
    const next = document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("ag-theme", next);
  }
  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

  function cycleFontSize() {
    const cur = document.documentElement.getAttribute("data-font-size") ?? "normal";
    const next = fontSizes[(fontSizes.indexOf(cur) + 1) % fontSizes.length];
    document.documentElement.setAttribute("data-font-size", next);
    localStorage.setItem("ag-font-size", next);
  }
  function toggleMotion() {
    const on = document.documentElement.getAttribute("data-reduced-motion") === "true";
    document.documentElement.setAttribute("data-reduced-motion", String(!on));
    localStorage.setItem("ag-reduced-motion", String(!on));
  }
  function toggleFaded() {
    const on = document.documentElement.getAttribute("data-colors") === "faded";
    document.documentElement.setAttribute("data-colors", on ? "normal" : "faded");
    localStorage.setItem("ag-faded-colors", String(!on));
  }

  document.getElementById("font-size-toggle")?.addEventListener("click", cycleFontSize);
  document.getElementById("font-size-toggle-mobile")?.addEventListener("click", cycleFontSize);

  document.getElementById("motion-toggle-nav")?.addEventListener("click", toggleMotion);
  document.getElementById("motion-toggle-mobile")?.addEventListener("click", toggleMotion);

  document.getElementById("faded-toggle-nav")?.addEventListener("click", toggleFaded);
  document.getElementById("faded-toggle-mobile")?.addEventListener("click", toggleFaded);

  function toggleClutter() {
    const on = document.documentElement.getAttribute("data-clutter-free") === "true";
    document.documentElement.setAttribute("data-clutter-free", String(!on));
    localStorage.setItem("ag-clutter-free", String(!on));
  }
  document.getElementById("clutter-toggle-nav")?.addEventListener("click", toggleClutter);
  document.getElementById("clutter-toggle-mobile")?.addEventListener("click", toggleClutter);

  // ── Initial sync ─────────────────────────────────────────────
  syncTheme();
  syncFontSize();
  syncMotion();
  syncFaded();
  syncClutter();

  // ── Scroll shadow ────────────────────────────────────────────
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 10) {
      navbar?.style.setProperty("box-shadow", "0 2px 12px 0 rgb(7 39 44 / 0.07)");
    } else {
      navbar?.style.removeProperty("box-shadow");
    }
  }, { passive: true });
</script>
