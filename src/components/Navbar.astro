---
const navLinks = [
  { href: '/', label: 'Hjem' },
  { href: '/hvad-er-autisme', label: 'Hvad er Autisme?' },
  { href: '/tilgaengelighed', label: 'Tilgængelighed' },
  { href: '/ressourcer', label: 'Ressourcer' },
  { href: '/uddannelse', label: 'Uddannelse' },
  { href: '/om-os', label: 'Om Os' },
];

const currentPath = Astro.url.pathname;
---

<header role="banner">
  <nav
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-300"
    style="background: var(--color-surface); border-color: var(--color-border);"
    aria-label="Primær navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-[4.5rem]">

        <!-- ─── Logo ─── -->
        <a
          href="/"
          class="flex items-center group flex-shrink-0"
          aria-label="AutismeGuiden – Gå til forsiden"
        >
          <!-- Icon only on mobile, full logo on desktop -->
          <img
            src="/autismeguiden_logo_1-2.png"
            alt="AutismeGuiden logo"
            width="40"
            height="40"
            class="block lg:hidden h-10 w-auto transition-transform duration-200 group-hover:scale-105"
          />
          <img
            src="/autismeguiden_logo.png"
            alt="AutismeGuiden"
            width="180"
            height="59"
            class="hidden lg:block h-10 w-auto transition-transform duration-200 group-hover:scale-105"
          />
        </a>

        <!-- ─── Desktop nav links ─── -->
        <div class="hidden lg:flex items-center gap-0.5" role="list">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-150"
                style={
                  isActive
                    ? 'background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);'
                    : 'color: var(--color-text-muted); font-family: var(--font-body);'
                }
                aria-current={isActive ? 'page' : undefined}
                role="listitem"
              >
                {label}
              </a>
            );
          })}
        </div>

        <!-- ─── Right controls ─── -->
        <div class="flex items-center gap-2">
          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg transition-all hover:opacity-80"
            style="color: var(--color-text-muted); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Skift tema"
            title="Skift mellem lyst og mørkt tema"
          >
            <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            class="lg:hidden flex flex-col items-center justify-center w-9 h-9 rounded-lg gap-1.5 transition-all"
            style="color: var(--color-text); background: var(--color-surface-2); border: 1.5px solid var(--color-border);"
            aria-label="Åbn menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span class="block w-5 h-0.5" style="background: currentColor;" id="bar1"></span>
            <span class="block w-5 h-0.5" style="background: currentColor;" id="bar2"></span>
            <span class="block w-4 h-0.5" style="background: currentColor;" id="bar3"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- ─── Mobile menu ─── -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden border-t"
      style="border-color: var(--color-border); background: var(--color-surface);"
      aria-label="Mobilmenu"
    >
      <div class="px-4 py-3 space-y-1">
        {navLinks.map(({ href, label }) => {
          const isActive = href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class="flex items-center px-3 py-2.5 rounded-lg text-sm font-semibold transition-all"
              style={
                isActive
                  ? 'background: var(--color-primary-50); color: var(--color-primary); font-family: var(--font-body);'
                  : 'color: var(--color-text-muted); font-family: var(--font-body);'
              }
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}

        <!-- Mobile dark mode -->
        <div class="pt-2 border-t" style="border-color: var(--color-border);">
          <button
            id="theme-toggle-mobile"
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold w-full transition-all hover:opacity-80"
            style="color: var(--color-text-muted); font-family: var(--font-body);"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
            <span id="theme-label-mobile">Skift til mørkt tema</span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed navbar -->
  <div class="h-16 lg:h-[4.5rem]" aria-hidden="true"></div>
</header>

<script>
  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  menuToggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', String(!isOpen));
    menuToggle.setAttribute('aria-label', isOpen ? 'Åbn menu' : 'Luk menu');
  });

  // Theme
  function updateThemeIcons() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('icon-sun')?.classList.toggle('hidden', !isDark);
    document.getElementById('icon-moon')?.classList.toggle('hidden', isDark);
    const mobileLabel = document.getElementById('theme-label-mobile');
    if (mobileLabel) mobileLabel.textContent = isDark ? 'Skift til lyst tema' : 'Skift til mørkt tema';
  }

  function toggleTheme() {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('ag-theme', next);
    updateThemeIcons();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
  updateThemeIcons();

  // Scroll shadow
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('shadow-sm', window.scrollY > 10);
  }, { passive: true });
</script>
