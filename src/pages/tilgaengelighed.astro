---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const principles = [
  {
    icon: '👁️',
    title: 'Opfatteligt (Perceivable)',
    wcag: 'Princip 1',
    items: [
      'Tekstalternativer til alt ikke-tekstindhold (billeder, ikoner, grafik)',
      'Tydelig farvekontrast — minimum 4,5:1 for brødtekst',
      'Indhold præsenteres ikke kun via farve alene',
      'Videoundertekster og lydbeskrivelser',
    ],
  },
  {
    icon: '⌨️',
    title: 'Betjenbart (Operable)',
    wcag: 'Princip 2',
    items: [
      'Al funktionalitet er tilgængelig via tastatur',
      'Ingen tastatur­fælder — brugere kan altid navigere videre',
      'Spring-til-indhold link øverst på siden',
      'Fokus­indikatorer er synlige og tydelige',
      'Ingen blinkende indhold over 3 Hz (risiko for epilepsi)',
    ],
  },
  {
    icon: '🗣️',
    title: 'Forståeligt (Understandable)',
    wcag: 'Princip 3',
    items: [
      'Sproget er angivet på siden (lang="da")',
      'Fejlmeddelelser er beskrivende og hjælpsomme',
      'Navigation er konsistent på tværs af sider',
      'Klart og enkelt sprog — undgå jargon',
      'Forudsigelig adfærd ved interaktioner',
    ],
  },
  {
    icon: '🔧',
    title: 'Robust (Robust)',
    wcag: 'Princip 4',
    items: [
      'Semantisk korrekt HTML-markup',
      'ARIA-etiketter og roller anvendt korrekt',
      'Kompatibel med skærmlæsere og hjælpeteknologier',
      'Fremtidssikret — virker i nye og ældre browsere',
    ],
  },
];

const goodBadExamples = [
  {
    type: 'good',
    title: 'God praksis: Fokus­indikatorer',
    description: 'Synlige, tydeligt afgrænsede fokus­ringe med høj kontrast på alle interaktive elementer.',
    example: 'Dette element har et tydelig fokusramme',
  },
  {
    type: 'bad',
    title: 'Dårlig praksis: Fjernede fokus­indikatorer',
    description: 'At skrive `outline: none` eller `outline: 0` fjerner tastaturnavigation for brugere der er afhængige af det.',
    example: 'Dette element har ingen synlig fokusring',
  },
  {
    type: 'good',
    title: 'God praksis: Beskrivende links',
    description: 'Links forklarer tydeligt, hvad der sker ved klik — uanset kontekst.',
    example: 'Læs om autismespektret på AutismeGuiden',
  },
  {
    type: 'bad',
    title: 'Dårlig praksis: Uklare links',
    description: '"Klik her" eller "Læs mere" giver ingen mening uden kontekst — især for skærmlæserbrugere.',
    example: 'Klik her',
  },
  {
    type: 'good',
    title: 'God praksis: Farvekontrast',
    description: 'Tekst på baggrunden har minimum 4,5:1 kontrastratio for normal tekst, 3:1 for stor tekst.',
    example: 'Denne tekst har høj kontrast',
  },
  {
    type: 'bad',
    title: 'Dårlig praksis: Lav kontrast',
    description: 'Lysegrå tekst på hvid baggrund er svær at læse for alle — og umulig for mange med syns­nedsættelse.',
    example: 'Svær at læse',
  },
];

const neurodivergentPrinciples = [
  {
    icon: '🧘',
    title: 'Rolig æstetik',
    desc: 'Undgå visuel støj. Brug rolige farver, tilstrækkelig whitespace og et klart hierarki. Ingen pludselige pop-ups, auto-afspilning eller blinkende elementer.',
  },
  {
    icon: '🔮',
    title: 'Forudsigelig navigation',
    desc: 'Navigation er konsistent på tværs af alle sider. Brugere ved altid, hvor de er, og hvad der sker, hvis de klikker på noget.',
  },
  {
    icon: '📏',
    title: 'Tydelig hierarki',
    desc: 'Brug overskrifter korrekt (H1, H2, H3). Tekst er opdelt i overskuelige blokke med generøs afstand. Vigtigste information først.',
  },
  {
    icon: '🎨',
    title: 'Farver med mening',
    desc: 'Farver understøtter kommunikation, men er aldrig det eneste signal. Altid kombineret med tekst, ikon eller form.',
  },
  {
    icon: '⚡',
    title: 'Reduceret sensorisk input',
    desc: 'Undgå uventede lyde, store farve­kontrast-spring, tæt­pakkede layouts og gentagne mønstre der kan virke overvældende.',
  },
  {
    icon: '🤲',
    title: 'Bruger­kontrol',
    desc: 'Giv brugerne mulighed for at justere: skriftstørrelse, tema, bevægelse. Respekter OS-indstillinger som prefers-reduced-motion.',
  },
  {
    icon: '💬',
    title: 'Klart sprog',
    desc: 'Brug enkelt, direkte dansk. Forklar fagudtryk. Undgå sarkasme, idiomer og tvetydige vendinger.',
  },
  {
    icon: '⏱️',
    title: 'Ingen tidspres',
    desc: 'Session-timeouts? Giv god varsel og tilstrækkelig tid. Formularer gemmer fremgang. Intet indhold forsvinder pludseligt.',
  },
];
---

<Layout
  title="Tilgængelighed – AutismeGuiden"
  description="Lær om WCAG 2.2, neurodivergent-venligt design og principper for tilgængelighed i digitale løsninger."
>
  <Hero
    badge="WCAG 2.2 Tilgængelighed"
    title="Design der virker for alle"
    description="Tilgængelighed er ikke en funktion — det er fundamentet. Her finder du principper, vejledninger og eksempler på inkluderende digitalt design."
    primaryCTA={{ label: 'WCAG principper', href: '#wcag' }}
    secondaryCTA={{ label: 'Neurodivergent design', href: '#neurodivergent' }}
    size="medium"
  />

  <!-- Our features -->
  <section class="section" aria-labelledby="features-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Denne hjemmeside"
        title="Tilgængeligheds­funktioner på AutismeGuiden"
        description="Jeg har implementeret disse funktioner for at gøre din oplevelse bedre."
        id="features-heading"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon: '🌙', title: 'Mørkt tema', desc: 'Reducer belastning af øjnene med et fuldt understøttet mørkt farvetema.' },
          { icon: 'A', title: 'Justerbar skriftstørrelse', desc: 'Vælg mellem normal, stor og ekstra stor tekst efter dine behov.' },
          { icon: '⚡', title: 'Reduceret bevægelse', desc: 'Slå animationer fra med ét klik — alle bevægelser forsvinder.' },
          { icon: '⌨️', title: 'Tastaturnavigation', desc: 'Komplet tastaturnavigation med synlige fokusringe på alle elementer.' },
          { icon: '🔗', title: 'Spring-til-indhold', desc: 'Et skjult link øverst på siden til at springe direkte til indhold.' },
          { icon: '🏷️', title: 'Semantisk HTML', desc: 'Korrekt brug af HTML5-semantik og ARIA for skærmlæsere.' },
          { icon: '🎨', title: 'Høj kontrast', desc: 'Alle farve­kombinationer overholder WCAG 2.2 kontrast­krav (AA).' },
          { icon: '📱', title: 'Responsivt design', desc: 'Virker på alle skærmstørrelser fra mobil til stor skærm.' },
          { icon: '💾', title: 'Præferencer huskes', desc: 'Dine tilgængeligheds­indstillinger gemmes til næste besøg.' },
        ].map(({ icon, title, desc }) => (
          <div class="card p-5 flex gap-4 items-start">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center text-lg font-bold flex-shrink-0"
              style="background: var(--color-primary-50); color: var(--color-primary);"
              aria-hidden="true"
            >
              {icon}
            </div>
            <div>
              <h3 class="font-semibold text-sm mb-1" style="color: var(--color-text);">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WCAG 4 principles -->
  <section id="wcag" class="section" style="background: var(--color-surface-2);" aria-labelledby="wcag-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="WCAG 2.2"
        title="De fire WCAG-principper"
        description="Web Content Accessibility Guidelines (WCAG) 2.2 er den internationale standard for tilgængelighed på nettet. Den bygger på fire principper."
        id="wcag-heading"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {principles.map(({ icon, title, wcag, items }) => (
          <article class="card p-6">
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
                style="background: var(--color-primary-50);"
                aria-hidden="true"
              >
                {icon}
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-primary);">{wcag}</p>
                <h3 class="font-bold text-base" style="color: var(--color-text);">{title}</h3>
              </div>
            </div>
            <ul class="space-y-2" role="list">
              {items.map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color: var(--color-secondary);" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <span class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <!-- Conformance levels -->
      <div class="mt-8 card p-6">
        <h3 class="font-bold text-lg mb-4" style="color: var(--color-text);">Konformitetsniveauer</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[
            { level: 'A', label: 'Niveau A', desc: 'Minimum krav. Basisniveau der fjerner de mest alvorlige barrierer.', color: 'var(--color-accent-amber)', bg: '#FEF3C7' },
            { level: 'AA', label: 'Niveau AA', desc: 'Standarden for de fleste offentlige og kommercielle websites. AutismeGuiden sigter mod AA.', color: 'var(--color-secondary)', bg: 'var(--color-secondary-50)' },
            { level: 'AAA', label: 'Niveau AAA', desc: 'Det højeste niveau. Ikke krævet for hele sider, men anbefales where muligt.', color: 'var(--color-primary)', bg: 'var(--color-primary-50)' },
          ].map(({ level, label, desc, color, bg }) => (
            <div class="rounded-xl p-4" style={`background: ${bg};`}>
              <div class="flex items-center gap-2 mb-2">
                <span class="font-bold text-xl" style={`color: ${color};`}>{level}</span>
                <span class="font-semibold text-sm" style="color: var(--color-text);">{label}</span>
              </div>
              <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Neurodivergent design -->
  <section id="neurodivergent" class="section" aria-labelledby="neuro-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Neurodivergent-venligt design"
        title="Design principper for alle neurotyper"
        description="Ud over WCAG er der ekstra overvejelser for at skabe bruger­oplevelser der er rare for autistiske og andre neurodivergente brugere."
        id="neuro-heading"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {neurodivergentPrinciples.map(({ icon, title, desc }) => (
          <div class="card p-5">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-3"
              style="background: var(--color-secondary-50);"
              aria-hidden="true"
            >
              {icon}
            </div>
            <h3 class="font-semibold text-sm mb-2" style="color: var(--color-text);">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Good vs Bad examples -->
  <section id="design" class="section" style="background: var(--color-surface-2);" aria-labelledby="examples-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Eksempler"
        title="God og dårlig praksis"
        description="Konkrete eksempler på hvad der virker og hvad der skaber barrierer."
        id="examples-heading"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {goodBadExamples.map(({ type, title, description, example }) => (
          <article
            class={`card overflow-hidden ${type === 'good' ? 'fact-box' : 'myth-box'}`}
            aria-label={title}
          >
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                {type === 'good' ? (
                  <span class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5"/>
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-wider text-green-700">God praksis</span>
                  </span>
                ) : (
                  <span class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-wider text-red-600">Dårlig praksis</span>
                  </span>
                )}
              </div>
              <h3 class="font-semibold text-base mb-2" style="color: var(--color-text);">{title}</h3>
              <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">{description}</p>
              <!-- Visual example -->
              <div
                class="rounded-lg p-3 text-sm font-medium"
                style={type === 'good'
                  ? 'background: white; border: 2px solid var(--color-primary); color: var(--color-text);'
                  : 'background: white; border: 2px dashed #F43F5E; color: #9CA3AF;'}
              >
                {type === 'good' ? (
                  <a href="#" class="focus-visible:ring-2 focus-visible:ring-primary rounded" onclick="return false;" style="color: var(--color-primary);">
                    {example}
                  </a>
                ) : (
                  <span style={example === 'Svær at læse' ? 'color: #C0C0C0;' : 'outline: none;'}>
                    {example}
                  </span>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" aria-label="Ressourcer om tilgængelighed">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4" style="color: var(--color-text);">
        Prøv tilgængeligheds­funktionerne
      </h2>
      <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
        Brug tilgængeligheds­panelet (knappen nede til højre) til at justere tema, skriftstørrelse og bevægelse.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/ressourcer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90" style="background: var(--color-primary); color: white;">
          Se alle ressourcer
        </a>
        <a href="/om-os" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-80" style="background: var(--color-surface); color: var(--color-text); border: 2px solid var(--color-border);">
          Om projektet
        </a>
      </div>
    </div>
  </section>
</Layout>
