---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ResourceCard from "../components/ResourceCard.astro";
import SectionHeader from "../components/SectionHeader.astro";

const quickNavCards = [
  {
    title: "Hvad er Autisme?",
    description: "Forstå autismespektret og neurodivergens med klare forklaringer, myter og fakta.",
    icon: "🧩",
    href: "/hvad-er-autisme",
    color: "primary" as const,
  },
  {
    title: "Tilgængelighed",
    description: "Designprincipper og vejledninger til neurodivergent-venlige digitale oplevelser.",
    icon: "♿",
    href: "/tilgaengelighed",
    color: "teal-dark" as const,
  },
  {
    title: "Ressourcer",
    description: "Et bibliotek med guides, artikler og værktøjer til neurodivergente og pårørende.",
    icon: "📚",
    href: "/ressourcer",
    color: "accent" as const,
  },
  {
    title: "Uddannelse",
    description: "Materiale og vejledninger til lærere og pædagoger om inklusion i klasseværelset.",
    icon: "🏫",
    href: "/uddannelse",
    color: "amber" as const,
  },
];

const featuredResources = [
  {
    title: "Introduktion til Autismespektret",
    description: "En grundlæggende guide til at forstå, hvad autisme er, og hvordan spektret ser ud i praksis.",
    category: "Grundviden",
    categoryColor: "var(--color-primary)",
    icon: "🧩",
    href: "/hvad-er-autisme",
    tags: ["Autisme", "Grundviden", "Spektret"],
    featured: true,
  },
  {
    title: "Sansebehandling og Autisme",
    description: "Lær om sensorisk overbelastning og hvordan man skaber rolige, autisme-venlige miljøer.",
    category: "Sensorik",
    categoryColor: "var(--color-primary)",
    icon: "🌊",
    href: "/ressourcer",
    tags: ["Sensorik", "Miljø"],
  },
  {
    title: "Kommunikationsstrategier",
    description: "Praktiske strategier til at kommunikere tydeligt og inkluderende med autistiske personer.",
    category: "Kommunikation",
    categoryColor: "var(--color-primary)",
    icon: "💬",
    href: "/ressourcer",
    tags: ["Kommunikation", "Strategier"],
  },
  {
    title: "Klasseværelset for Alle",
    description: "Vejledning til lærere om tilpasning og inklusion i folkeskolen og gymnasiet.",
    category: "Uddannelse",
    categoryColor: "var(--color-accent)",
    icon: "🏫",
    href: "/uddannelse",
    tags: ["Lærere", "Inklusion"],
  },
];

const stats = [
  { value: "1 ud af 60", label: "børn i Danmark er autistiske" },
  { value: "700.000+", label: "danskere er neurodivergente" },
  { value: "WCAG 2.2", label: "tilgængelighedsstandard" },
  { value: "Gratis", label: "åben og fri information" },
];
---

<Layout
  title="AutismeGuiden – Din guide til autisme og neurodivergens"
  description="AutismeGuiden er en gratis, tilgængelig platform med information om autisme og neurodivergens for neurodivergente, pårørende, lærere og fagfolk."
  ogtitle="Din guide til autisme og neurodivergens | AutismeGuiden"
  ogdescription="Gratis, tilgængelig information om autisme og neurodivergens til neurodivergente, pårørende, lærere og fagfolk."
>
  <!-- Hero -->
  <Hero
    badge="Autisme · ADHD · Neurodivergens"
    title="Din guide til autisme og neurodivergens"
    description="Klar, tilgængelig information om autisme og neurodivergens – til neurodivergente, pårørende og fagfolk."
    primaryCTA={{ label: "Udforsk guiden", href: "/hvad-er-autisme" }}
    secondaryCTA={{ label: "Se ressourcer", href: "/ressourcer" }}
  />

  <!-- Stats bar -->
  <section
    class="py-10 border-y"
    style="border-color: var(--color-border); background: var(--color-surface);"
    aria-label="Nøgletal"
    data-animate="animate__fadeInUp"
    data-delay="150"
    data-extra-section
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {
          stats.map(({ value, label }) => (
            <div class="text-center">
              <dt
                class="text-2xl sm:text-3xl font-bold mb-1"
                style="font-family: var(--font-display); color: var(--color-primary); letter-spacing: 0.04em;"
              >
                {value}
              </dt>
              <dd class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">
                {label}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Mission -->
  <section class="section" aria-labelledby="mission-heading" data-animate="animate__fadeInUp" data-delay="150">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="color: var(--color-primary); font-family: var(--font-body); letter-spacing: 0.12em;"
          data-clutter
        >
          Min mission
        </p>
        <h2
          id="mission-heading"
          class="font-bold tracking-wide leading-tight mb-6 text-3xl sm:text-4xl"
          style="font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.04em;"
        >
          Information der møder dig, hvor du er
        </h2>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-muted); font-family: var(--font-body);">
          Jeg tror på, at alle fortjener adgang til præcis, fordomsfri og letforståelig information. AutismeGuiden har autisme som primær fokus, men
          rummer ressourcer for hele det neurodivergente fællesskab&mdash; autistiske, ADHD'ere, ordblinde og deres pårørende.
        </p>
        <blockquote class="highlight-box text-left rounded-xl">
          <p class="text-sm leading-relaxed font-reading" style="color: var(--color-text);">
            <strong class="italic" style="color: var(--color-primary);"
              >"At tænke og opleve verden anderledes er ikke en fejl, der skal rettes. Det er en del af hvem du er. AutismeGuiden er bygget på respekt
              for neurodiversitet og styrken ved at være forskellig."</strong
            >
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Quick nav cards -->
  <section
    class="section"
    style="background: var(--color-surface-2);"
    aria-labelledby="nav-cards-heading"
    data-animate="animate__fadeInUp"
    data-delay="150"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Find det du søger"
        title="Hvad kan AutismeGuiden hjælpe dig med?"
        description="AutismeGuiden er opdelt i fire hovedområder, så du hurtigt finder den information, du har brug for."
        id="nav-cards-heading"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6" data-animate="animate__fadeInUp" data-delay="200">
        {
          quickNavCards.map((card) => (
            <FeatureCard title={card.title} description={card.description} icon={card.icon} href={card.href} color={card.color} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured resources -->
  <section class="section" aria-labelledby="resources-heading" data-animate="animate__fadeInUp" data-delay="150">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12" data-animate="animate__fadeInUp" data-delay="150">
        <SectionHeader
          eyebrow="Populære ressourcer"
          title="Udvalgte guides og artikler"
          description="Det mest besøgte indhold på AutismeGuiden."
          centered={false}
          id="resources-heading"
        />
        <a
          href="/ressourcer"
          class="shrink-0 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest transition-all hover:gap-3"
          style="color: var(--color-primary); font-family: var(--font-body); letter-spacing: 0.08em;"
          aria-label="Se alle ressourcer"
        >
          Se alle ressourcer
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {featuredResources.map((resource) => <ResourceCard {...resource} />)}
      </div>
    </div>
  </section>

  <!-- CTA band — always-dark section, uses --cta-dark-* tokens -->
  <section
    class="section"
    style="background: var(--cta-dark-bg);"
    aria-labelledby="design-teaser-heading"
    data-animate="animate__fadeInUp"
    data-delay="150"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center" data-animate="animate__fadeInUp" data-delay="200">
        <p
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="color: var(--cta-dark-text); font-family: var(--font-body); letter-spacing: 0.12em;"
          data-clutter
        >
          Design med omtanke
        </p>
        <h2
          id="design-teaser-heading"
          class="font-bold tracking-wide leading-tight mb-6 text-3xl sm:text-4xl"
          style="font-family: var(--font-display); color: var(--cta-dark-heading); letter-spacing: 0.04em;"
        >
          Bygget til neurodivergente brugere
        </h2>
        <p class="text-lg leading-relaxed mb-8" style="color: var(--cta-dark-text); font-family: var(--font-body);">
          Denne hjemmeside er designet efter WCAG 2.2-standarderne med mørkt tema, justerbar skriftstørrelse og reduceret bevægelse&mdash; fordi alle
          fortjener en god oplevelse.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/tilgaengelighed"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-sm uppercase tracking-widest transition-all hover:opacity-90 active:scale-[0.98]"
            style="background: var(--color-accent); color: white; font-family: var(--font-body); letter-spacing: 0.06em;"
          >
            Læs om designprincipper
          </a>
          <button
            id="open-toolbar-hero"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-sm uppercase tracking-widest transition-all hover:opacity-80 border-2"
            style="color: var(--cta-dark-heading); border-color: var(--cta-dark-border); background: transparent; font-family: var(--font-body); letter-spacing: 0.06em;"
            aria-label="Åbn tilgængelighedsindstillinger"
            data-clutter
          >
            Tilgængeligheds­funktioner
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section class="section" aria-labelledby="audiences-heading" data-animate="animate__fadeInUp" data-delay="150">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="For alle"
        title="Guiden er for dig"
        description="Uanset hvem du er, er der indhold på AutismeGuiden der passer til dig."
        id="audiences-heading"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {
          [
            {
              icon: "🧩",
              title: "Neurodivergente",
              desc: "Autisme, ADHD, ordblindhed, mm. – information, ressourcer og støtte til dig.",
              href: "/ressourcer",
            },
            { icon: "👨‍👩‍👧", title: "Pårørende", desc: "Forstå og støt dine nærmeste på den bedste måde.", href: "/hvad-er-autisme" },
            { icon: "🏫", title: "Lærere", desc: "Skab et inkluderende læringsmiljø for alle elever.", href: "/uddannelse" },
            { icon: "🏥", title: "Fagfolk", desc: "Faglig viden, vejledninger og evidensbaserede ressourcer.", href: "/ressourcer" },
          ].map(({ icon, title, desc, href }) => (
            <a href={href} class="card card-interactive flex flex-col items-center text-center p-6 group" aria-label={`${title} – ${desc}`}>
              <div
                class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-4 transition-transform group-hover:scale-110"
                style="background: var(--color-primary-50);"
                aria-hidden="true"
              >
                {icon}
              </div>
              <h3 class="font-bold text-base mb-2" style="font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.03em;">
                {title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted); font-family: var(--font-body);">
                {desc}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section
    class="section"
    style="background: var(--color-surface-2);"
    aria-labelledby="cta-heading"
    data-animate="animate__fadeInUp"
    data-delay="150"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        id="cta-heading"
        class="font-bold tracking-wide mb-4 text-3xl sm:text-4xl"
        style="font-family: var(--font-display); color: var(--color-text); letter-spacing: 0.04em;"
      >
        Har du spørgsmål?
      </h2>
      <p class="text-lg leading-relaxed mb-8" style="color: var(--color-text-muted); font-family: var(--font-body);">
        Jeg er her for at hjælpe. Skriv til mig, eller browse ressourcebiblioteket.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="/om-os#kontakt"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-bold text-sm uppercase tracking-widest transition-all hover:opacity-90 active:scale-[0.98]"
          style="background: var(--color-primary); color: var(--color-on-primary); font-family: var(--font-body); letter-spacing: 0.06em;"
        >
          Skriv til mig
        </a>
        <a
          href="/ressourcer"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-bold text-sm uppercase tracking-widest transition-all hover:opacity-80 active:scale-[0.98]"
          style="background: var(--color-surface); color: var(--color-primary); border: 2px solid var(--color-border-strong); font-family: var(--font-body); letter-spacing: 0.06em;"
        >
          Ressourcebibliotek
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.getElementById("open-toolbar-hero")?.addEventListener("click", () => {
    const toolbar = document.getElementById("accessibility-toolbar");
    const backdrop = document.getElementById("toolbar-backdrop");
    if (toolbar && backdrop) {
      toolbar.classList.remove("translate-x-full");
      toolbar.classList.add("translate-x-0");
      toolbar.setAttribute("aria-hidden", "false");
      backdrop.classList.remove("hidden");
      document.getElementById("toolbar-close")?.focus();
      document.body.style.overflow = "hidden";
    }
  });
</script>
