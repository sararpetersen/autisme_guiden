---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import SectionHeader from "../components/SectionHeader.astro";

const mythsFacts = [
  {
    myth: "Autistiske mennesker har ingen empati.",
    fact: "Autistiske personer kan have stærk empati, men udtrykker den ofte på andre måder. Studier viser, at mange autistiske personer faktisk føler dyb empati, men de kan bare have svært ved at vise det på de forventede måder.",
  },
  {
    myth: "Autisme skyldes dårlig opdragelse.",
    fact: "Autisme er en neurologisk forskel, der er til stede fra fødslen. Forskning viser, at genetiske og biologiske faktorer spiller en central rolle. Forældre og opdragelse har ingen indflydelse på, om et barn er autistisk.",
  },
  {
    myth: "Alle autistiske er geniale inden for ét område.",
    fact: "Mens nogle autistiske har særlige interesser eller færdigheder, er dette ikke universelt. Autismespektret er meget bredt og forskelligartet, og ingen to autistiske er ens.",
  },
  {
    myth: "Autisme kan helbredes.",
    fact: 'Autisme er ikke en sygdom, men en neurotype— en del af menneskelig neurodiversitet. Man hverken skal eller kan "helbrede" autisme. Målet er at støtte autistiske mennesker i at trives og leve gode liv på egne betingelser.',
  },
  {
    myth: "Autistiske kan ikke have nære relationer.",
    fact: "Mange autistiske har dybe og meningsfulde venskaber, parforhold og familiebånd. De måder, de danner og vedligeholder relationer på, kan se anderledes ud, men de er ikke mindre ægte.",
  },
  {
    myth: "Autisme og ADHD er kun noget, drenge har.",
    fact: 'Autisme og ADHD forekommer hos alle køn, men er historisk set underdiagnosticeret hos piger og kvinder, da de oftere lærer at "maskere", altså at efterligne neurotypisk adfærd for at passe ind.',
  },
  {
    myth: 'Autistiske mennesker skal "fikses".',
    fact: "Autisme er ikke en fejl, der skal rettes— det er en naturlig variation i menneskelig kognition. Målet bør være støtte, tilgængelighed og inklusion, ikke normalisering. Autistiske mennesker behøver ikke at ændre sig for at passe ind i verden; omgivelserne skal tilpasse sig dem.",
  },
];

const faqItems = [
  {
    question: "Hvad er autisme?",
    answer:
      "Autisme <em>(eller autismespektrumforstyrrelse, ASF)</em> er en neurologisk forskel, der påvirker, hvordan man oplever og interagerer med verden. Det handler om forskelligheder i social kommunikation, sensorisk behandling og adfærdsmønstre. Autisme er et spektrum, og ingen to autistiske er ens.",
  },
  {
    question: 'Hvad betyder <em>"autismespektret"</em>?',
    answer:
      "Spektret beskriver den store variation i, hvordan autisme viser sig. Nogle autistiske har brug for meget støtte i dagligdagen, andre er fuldt selvstændige. Udfordringer og styrker varierer enormt fra person til person. Tidligere brugte man betegnelser som Asperger's syndrom og infantil autisme, men disse er nu samlet under ét spektrum.",
  },
  {
    question: "Hvordan stilles en autismediagnose?",
    answer:
      "En autismediagnose stilles af specialiserede fagfolk— typisk psykologer eller psykiatere —gennem samtaler, observationer og standardiserede tests. Der er ingen blodprøve eller scanning, der kan påvise autisme. Mange får først en diagnose i voksenalderen, særligt kvinder og non-binære, fordi diagnosticeringskriterierne historisk har taget udgangspunkt i drenge.",
  },
  {
    question: 'Hvad er <em>"masking"</em> eller <em>"camouflering"</em>?',
    answer:
      "Masking eller camouflering er, når autistiske personer bevidst eller ubevidst skjuler autistiske træk for at passe ind socialt. Det kan inkludere at imitere andres sociale adfærd, undertrykke stimming eller tvinge sig selv til øjenkontakt. Masking er mentalt udmattende og forbindes med øget risiko for autistisk udbrændthed.",
  },
  {
    question: "Hvad er sensorisk sensitivitet?",
    answer:
      "Mange autistiske oplever sensorisk over- eller underfølsomhed, eller begge dele på forskellige tidspunkter. Det betyder, at sanseindtryk som lyd, lys, lugt, berøring eller teksturer kan opleves meget stærkere eller svagere end for de fleste. Sensorisk overbelastning kan føre til ekstrem ubehag, nedlukning eller meltdowns.",
  },
  {
    question: "Hvad er autistisk udbrændthed?",
    answer:
      "Autistisk udbrændthed opstår, når en person over tid har brugt for mange ressourcer på at tilpasse sig neurotypiske omgivelser— ofte gennem masking. Det kan vise sig som ekstrem træthed, tab af færdigheder man normalt mestrer, og øget sensorisk følsomhed. Det adskiller sig fra almindelig stress og kræver tid og ro at komme sig over.",
  },
  {
    question: "Er autisme arvelig?",
    answer:
      "Forskning tyder på, at genetik spiller en betydelig rolle. Autisme forekommer oftere i familier, hvor andre familiemedlemmer også er autistiske eller neurodivergente. Der er dog ikke én enkelt gen-variant, der forklarer autisme; det er et komplekst samspil mellem mange faktorer. Autisme skyldes ikke opdragelse, vaccines eller kost.",
  },
  {
    question: "Hvad er sammenhængen mellem autisme og ADHD?",
    answer:
      "Autisme og ADHD er begge udtryk for neurodivergens og forekommer ofte sammen. Studier tyder på, at op til 50-70% af autistiske også har ADHD. De deler overlappende træk som vanskeligheder med eksekutive funktioner og sensorisk følsomhed, men er to adskilte diagnoser med forskellige kernetræk.",
  },
];

const spectrumAreas = [
  {
    icon: "💬",
    title: "Social kommunikation",
    desc: "Forskel i, hvordan man kommunikerer, fortolker sociale signaler og interagerer med andre.",
  },
  {
    icon: "🔁",
    title: "Mønstre og rutiner",
    desc: "Stærkt behov for forudsigelighed, rutiner og systematisk tænkning. Intense interesser.",
  },
  {
    icon: "🌊",
    title: "Sensorisk behandling",
    desc: "Over- eller under-følsomhed over for lyd, lys, lugt, smag og berøring.",
  },
  {
    icon: "🧠",
    title: "Eksekutive funktioner",
    desc: "Udfordringer med planlægning, skift af fokus, hukommelse og tidsfornemmelse.",
  },
];
---

<Layout
  title="Hvad er Autisme? – AutismeGuiden"
  description="Lær om autismespektret, myter og fakta, og få svar på de mest stillede spørgsmål om autisme på en tilgængelig og fordomsfri måde."
  ogtitle="Hvad er autisme? Kort intro | AutismeGuiden"
  ogdescription="En kort, tilgængelig introduktion til autismespektret, myter og vigtige fakta."
>
  <Hero
    badge="Grundviden"
    title="Hvad er autisme?"
    description="Autisme er ikke en sygdom, det er en neurologisk forskel – og én del af det neurodivergente spektrum. Her finder du klar, fordomsfri viden om autisme og hverdagen med autisme."
    primaryCTA={{ label: "Læs om myter og fakta", href: "#myter-og-fakta" }}
    secondaryCTA={{ label: "Ofte stillede spørgsmål", href: "#faq" }}
    size="medium"
  />

  <!-- Spectrum intro -->
  <section class="section" aria-labelledby="spektrum-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-primary);">Autismespektret</p>
          <h2 id="spektrum-heading" class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-6" style="color: var(--color-text);">
            Et spektrum, ikke én boks
          </h2>
          <div class="space-y-4 prose-reading" style="color: var(--color-text-muted);">
            <p>
              Autismespektrumforstyrrelse (ASF) er en samlet betegnelse for en bred vifte af udtryk for neurodivergens. Ingen to autistiske er
              ens&mdash; spektret er bredt, og mange kombinationer af styrker og udfordringer er mulige.
            </p>
            <p>
              Den medicinske forståelse af autisme er under konstant udvikling. I dag bruger man ét samlet spektrum i stedet for separate diagnoser
              som Aspergers syndrom og infantil autisme.
            </p>
            <p>Autisme identificeres typisk ved forskelle inden for fire overordnede områder, men husk: det er et spektrum, ikke en checkliste.</p>
          </div>

          <div class="mt-8 p-5 rounded-2xl" style="background: var(--color-primary-100);">
            <p class="text-sm font-semibold mb-2" style="color: var(--color-primary);">Vidste du det?</p>
            <p class="text-sm leading-relaxed font-reading" style="color: var(--color-text);">
              Anslået 1-2% af alle mennesker, svarende til over 700.000+ danskere, har en neurodivergent profil. Mange er dog endnu ikke
              diagnosticerede.
            </p>
          </div>
        </div>

        <!-- Spectrum areas grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            spectrumAreas.map(({ icon, title, desc }) => (
              <div class="card p-5">
                <div
                  class="w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-3"
                  style="background: var(--color-primary-50);"
                  aria-hidden="true"
                >
                  {icon}
                </div>
                <h3 class="font-semibold text-sm mb-2" style="color: var(--color-text);">
                  {title}
                </h3>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                  {desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Myth vs Fact -->
  <section id="myter-og-fakta" class="section" style="background: var(--color-surface-2);" aria-labelledby="myter-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Myter og fakta"
        title="Sæt rekorden lige"
        description="Der eksisterer mange misforståelser om autisme. Her rydder jeg op i de mest udbredte myter."
        id="myter-heading"
      />

      <div class="space-y-6">
        {
          mythsFacts.map(({ myth, fact }, i) => (
            <article class="card overflow-hidden" aria-label={`Myte ${i + 1}`}>
              <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="myth-box p-5 md:p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="badge-red-circle w-6 h-6 rounded-full bg-red-100 flex items-center justify-center shrink-0" aria-hidden="true">
                      <svg class="w-3.5 h-3.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path d="M18 6L6 18M6 6l12 12" />
                      </svg>
                    </span>
                    <span class="text-xs font-bold uppercase tracking-wider text-red-600">Myte</span>
                  </div>
                  <p class="text-sm leading-relaxed font-medium" style="color: var(--color-text);">
                    {myth}
                  </p>
                </div>
                <div class="fact-box p-5 md:p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="w-6 h-6 rounded-full flex items-center justify-center shrink-0" style="background: var(--color-primary-100);" aria-hidden="true">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color: var(--color-primary);">
                        <path d="M20 6L9 17l-5-5" />
                      </svg>
                    </span>
                    <span class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-primary);">
                      Fakta
                    </span>
                  </div>
                  <p class="text-sm leading-relaxed font-reading" style="color: var(--color-text);">
                    {fact}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Key concepts -->
  <section class="section" aria-labelledby="begreber-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Vigtige begreber"
        title="Ord du bør kende"
        description="En guide til de vigtigste termer inden for autismeforståelse."
        id="begreber-heading"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          [
            {
              term: "Neurodivergens",
              def: "Tilstanden at have en hjerne, der fungerer anderledes end den neurologiske majoritet. Bruges om den enkelte person, modsat neurotypisk.",
            },
            {
              term: "Neurodiversitet",
              def: "Den naturlige variation i neurologiske typer hos mennesker som helhed. Begrebet fremhæver, at neurologisk mangfoldighed er en styrke for samfundet, og ikke en fejl der skal rettes.",
            },
            {
              term: "Neurodivers",
              def: "Adjektiv der beskriver fællesskaber, miljøer eller grupper, som indeholder og anerkender mange neurologiske varianter. Et neurodivers samfund giver plads til alle neurotyper.",
            },
            {
              term: "Sær-interesser",
              def: 'Et emne eller en aktivitet som en neurodivergent person er intenst og dybt optaget af. Sær-interesser er en kilde til glæde, identitet og ekspertviden— ikke blot en "hobby".',
            },
            {
              term: "Masking/camouflering",
              def: "Når neurodivergente bevidst eller ubevidst skjuler deres træk for at passe ind socialt. Kan føre til udbrændthed.",
            },
            {
              term: "Nedsmeltning/meltdown",
              def: "En ufrivillig reaktion på overbelastning, hvor kroppen og sindet mister kontrollen. Ikke en tantrum eller opførselsproblem.",
            },
            {
              term: "Nedlukning/shutdown",
              def: "En reaktion på overbelastning, hvor man trækker sig ind i sig selv og bliver ude af stand til at kommunikere eller handle.",
            },
            { term: "Stimming", def: "Selvstimulerende adfærd som at gynge, klappe eller nynne. Hjælper med at regulere sanserne og følelser." },
            {
              term: "Executive functions/eksekutive funktioner",
              def: "Kognitive evner til planlægning, organisering, skift af opgave og impulskontrol. Ofte udfordrende for neurodivergente.",
            },
            {
              term: "Sensory processing/sensorisk bearbejdning",
              def: "Hjernens måde at bearbejde sanseindtryk. Mange neurodivergente er hyper- eller hypo-sensitive over for lyde, lys osv.",
            },
            {
              term: "AAK <em>(Augmentativ og Alternativ Kommunikation)</em>",
              def: "Hjælpemidler til kommunikation for ikke-talende eller minimalt talende folk med neurologiske problemer.",
              link: { href: "https://dk.tobiidynavox.com/pages/what-is-aac", label: "Hvad er AAC?" },
            },
            {
              term: "Spoonies/Spoon Theory",
              def: "En metafor for begrænsede energiressourcer hos folk med kroniske tilstande, herunder mange neurodivergente.",
              link: { href: "https://hdsunflower.com/dk/insights/post/spoon-theory", label: "Spoon Theory" },
            },
          ].map(({ term, def, link }) => (
            <div class="card p-5">
              <h3 class="font-bold text-sm mb-2" style="color: var(--color-primary);" set:html={term} />
              <p class="text-sm leading-relaxed font-reading mb-2" set:html={def} style="color: var(--color-text-muted);" />
              {link && (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 mt-2 text-xs font-semibold"
                  style="color: var(--color-primary);"
                >
                  {link.label}
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6m0 0v6m0-6L10 14" />
                  </svg>
                  <span class="sr-only">(åbner i nyt faneblad)</span>
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section" style="background: var(--color-surface-2);" aria-labelledby="faq-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader eyebrow="FAQ" title="Ofte stillede spørgsmål" description="De mest stillede spørgsmål om autisme." id="faq-heading" />
      <FAQAccordion items={faqItems} id="autism-faq" />
    </div>
  </section>

  <!-- CTA -->
  <section class="section" aria-label="Næste skridt">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4" style="color: var(--color-text);">Klar til at lære mere?</h2>
      <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
        Udforsk ressourcebiblioteket eller læs om, hvordan du kan støtte autistiske elever i uddannelse.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="/ressourcer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90"
          style="background: var(--color-primary); color: var(--color-on-primary);"
        >
          Ressourcebibliotek
        </a>
        <a
          href="/uddannelse"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-80"
          style="background: var(--color-surface); color: var(--color-primary); border: 2px solid var(--color-border-strong);"
        >
          Uddannelsesvejledning
        </a>
      </div>
    </div>
  </section>
</Layout>
